---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, projectUrl } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="article-header">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								(Updated <FormattedDate date={updatedDate} />)
							</span>
						)}
					</div>
					<h1>{title}</h1>
					<p class="description">{description}</p>
					{projectUrl && (
						<a href={projectUrl} class="project-button">
							Visit project →
						</a>
					)}
					<div class="header-seam" aria-hidden="true"></div>
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1200} height={630} src={heroImage} alt={title} />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>

				<footer class="article-footer">
					<a href="/blog" class="back-link">
						<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
							<path fill="currentColor" d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
						</svg>
						All writing
					</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 100%;
		padding: 0;
	}

	article {
		max-width: 720px;
		margin: 0 auto;
		padding: var(--space-xl) var(--space-lg);
	}

	/* Article header */
	.article-header {
		margin-bottom: 2.5rem;
	}

	.meta {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--ink-muted);
		margin-bottom: 1rem;
	}

	.updated {
		font-style: italic;
	}

	.article-header h1 {
		font-size: clamp(2rem, 4.5vw, 2.8rem);
		font-weight: 500;
		line-height: 1.15;
		margin-bottom: 1rem;
	}

	.description {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.25rem;
		color: var(--ink-soft);
		max-width: 640px;
		line-height: 1.5;
		margin-bottom: 0;
	}

	.header-seam {
		width: 64px;
		height: 3px;
		background: var(--seam);
		border-radius: 2px;
		margin-top: 1.75rem;
	}

	.project-button {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.375rem;
		margin-top: 1.5rem;
		background: var(--ink);
		color: var(--paper);
		text-decoration: none;
		border-radius: var(--radius-md);
		font-weight: 500;
		font-size: 0.9375rem;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.project-button:hover {
		background: #3b342b;
		color: var(--paper);
		transform: translateY(-1px);
	}

	/* Hero image */
	.hero-image {
		margin: 0 0 2.5rem;
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--line);
	}

	.hero-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	/* Article footer */
	.article-footer {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--line);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--ink-soft);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.back-link:hover {
		color: var(--rule-deep);
		gap: 0.75rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		article {
			padding: var(--space-lg) var(--space-md);
		}

		.description {
			font-size: 1.125rem;
		}
	}
</style>

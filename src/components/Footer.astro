---
import { SOCIAL_LINKS } from '../consts';
const today = new Date();
---

<footer>
	<div class="seam-edge" aria-hidden="true"></div>
	<div class="footer-container">
		<div class="footer-main">
			<span class="footer-name">Max Ghenis</span>
			<p class="footer-tagline">Open models of how policy works — the rules as written, and what happens next.</p>
		</div>

		<div class="footer-links">
			<div class="footer-column">
				<h4>Explore</h4>
				<a href="/">Home</a>
				<a href="/blog">Writing</a>
				<a href="/projects">Projects</a>
				<a href="/lab">Lab</a>
				<a href="/cv">CV</a>
			</div>
			<div class="footer-column">
				<h4>More</h4>
				<a href="/setup">Setup</a>
				<a href="/usage">Usage</a>
				<a href="/protocol">Protocol</a>
				<a href="/feed">Feed</a>
			</div>
			<div class="footer-column">
				<h4>Connect</h4>
				<a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener">X / Twitter</a>
				<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">LinkedIn</a>
				<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub</a>
				<a href={SOCIAL_LINKS.bluesky} target="_blank" rel="noopener">Bluesky</a>
				<a href={`mailto:${SOCIAL_LINKS.email}`}>Email</a>
			</div>
			<div class="footer-column">
				<h4>Subscribe</h4>
				<a href="/rss.xml">RSS feed</a>
				<a href={SOCIAL_LINKS.substack} target="_blank" rel="noopener">Substack</a>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} Max Ghenis. Content is open source.</p>
		<a href="https://github.com/maxghenis/maxghenis.com" target="_blank" rel="noopener" class="source-link">
			<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
				<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
			</svg>
			View source
		</a>
	</div>
</footer>

<style>
	footer {
		margin-top: 4rem;
		background: #211d18;
		color: #f4f1e9;
	}

	.seam-edge {
		height: 2px;
		background: var(--seam);
	}

	.footer-container {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 4rem;
		max-width: 1100px;
		margin: 0 auto;
		padding: 3.5rem 2rem 3rem;
	}

	/* Brand section */
	.footer-name {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		display: block;
		margin-bottom: 0.625rem;
	}

	.footer-tagline {
		color: rgba(244, 241, 233, 0.55);
		font-size: 0.9375rem;
		line-height: 1.6;
		margin: 0;
		max-width: 300px;
	}

	/* Links section */
	.footer-links {
		display: flex;
		gap: 3.5rem;
	}

	.footer-column {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-column h4 {
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: rgba(244, 241, 233, 0.4);
		margin-bottom: 0.5rem;
	}

	.footer-column a {
		color: rgba(244, 241, 233, 0.72);
		text-decoration: none;
		font-size: 0.9375rem;
		transition: color var(--duration-fast) var(--ease-out);
	}

	.footer-column a:hover {
		color: #e9b98a;
	}

	/* Bottom bar */
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.5rem 2rem;
		border-top: 1px solid rgba(244, 241, 233, 0.1);
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.875rem;
		color: rgba(244, 241, 233, 0.4);
	}

	.source-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: rgba(244, 241, 233, 0.4);
		text-decoration: none;
		font-size: 0.875rem;
		transition: color var(--duration-fast) var(--ease-out);
	}

	.source-link:hover {
		color: #e9b98a;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.footer-container {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			padding: 2.5rem 1.5rem 2rem;
		}

		.footer-links {
			flex-wrap: wrap;
			gap: 2rem;
		}

		.footer-column {
			min-width: 120px;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
			padding: 1.5rem;
		}
	}
</style>

---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_LINKS, NEWSLETTER_URL } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);

const work = [
	{
		title: 'PolicyBench',
		href: 'https://policybench.org',
		description: 'Open benchmark scoring AI models on tax and benefit law, graded against exact calculations.',
		tag: 'AI eval',
		pole: 'cast',
	},
	{
		title: 'populace',
		href: 'https://populace.dev',
		description: 'Calibrated survey microdata for policy simulation — national to local, fully reproducible.',
		tag: 'Microdata',
		pole: 'cast',
	},
	{
		title: 'OpenMessage',
		href: 'https://github.com/MaxGhenis/openmessage',
		description: 'macOS Google Messages client that gives coding agents access to your texts.',
		tag: 'macOS',
		pole: 'rule',
	},
	{
		title: "MacKenzie Scott's giving, in QALYs",
		href: '/mackenzie-scott-qaly',
		description: "GiveWell-style Monte Carlo model of $26.3B in giving, running entirely in your browser.",
		tag: 'Monte Carlo',
		pole: 'cast',
	},
	{
		title: 'microdf',
		href: 'https://github.com/PolicyEngine/microdf',
		description: "Pandas extensions for weighted survey microdata, used across PolicyEngine's models.",
		tag: 'Python',
		pole: 'rule',
	},
	{
		title: 'TerminalGrid',
		href: '/terminalgrid',
		description: 'VS Code extension for keyboard-driven terminal grids, built for agentic coding.',
		tag: 'VS Code',
		pole: 'rule',
	},
];

const research = [
	{
		title: 'Enhancing survey microdata with administrative records',
		href: 'https://github.com/PolicyEngine/policyengine-us-data/blob/main/paper/main.pdf',
		description: 'Microsimulation dataset construction. Presented at NTA 2024.',
		date: '2024',
	},
	{
		title: 'What can LLMs tell us about the ETI?',
		href: 'https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5410643',
		description: 'With Jason DeBacker. How language models perceive behavioral responses to tax policy.',
		date: '2025',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1 class="hero-title">
					Simulating futures<br class="title-break" />
					to build the one we want.
				</h1>
				<p class="hero-sub">
					I build open-source software that
					<span class="u-rule">computes what the law says</span>,
					<span class="u-want">measures what it does</span>, and
					<span class="u-cast">projects what happens next</span>.
				</p>
				<div class="hero-meta">
					<img src="/images/headshot.png" alt="Max Ghenis" class="hero-photo" />
					<span class="hero-role">CEO, The Axiom Foundation &amp; PolicyEngine · Washington, DC</span>
				</div>
				<div class="hero-actions">
					<a href={`mailto:${SOCIAL_LINKS.email}`} class="btn-primary">Get in touch</a>
					<a href="/projects" class="btn-quiet">See the work →</a>
				</div>
			</section>

			<!-- The three poles, stated plainly -->
			<section class="poles-strip">
				<div class="poles">
					<div class="pole">
						<span class="pole-tag rule-tag">Rules</span>
						<span class="pole-copy">what the law says — exact, cited, computable</span>
					</div>
					<div class="pole pole-mid">
						<span class="pole-tag want-tag">Impacts</span>
						<span class="pole-copy">what it does — for any household, for whole populations</span>
					</div>
					<div class="pole pole-right">
						<span class="pole-tag cast-tag">Projections</span>
						<span class="pole-copy">what happens next — modeled openly, revised as law changes</span>
					</div>
				</div>
			</section>

			<!-- Work -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Work</span>
				</div>

				<a href="https://axiom-foundation.org" class="featured" target="_blank" rel="noopener">
					<div class="featured-seam featured-rule" aria-hidden="true"></div>
					<div class="featured-body">
						<span class="featured-role">Founder &amp; CEO · 2026—</span>
						<h2>The Axiom Foundation</h2>
						<p>
							Publishes the law as open, verified code — every value citing
							its statute, every clause carrying its effective date, every
							encoding checked against independent implementations. Launches
							publicly July 28; PolicyEngine becomes its first and most
							demanding consumer.
						</p>
						<span class="featured-link">axiom-foundation.org →</span>
					</div>
					<div class="featured-logo">
						<img src="/assets/logos/axiom-mark.svg" alt="" width="72" height="72" />
					</div>
				</a>

				<a href="https://policyengine.org" class="featured" target="_blank" rel="noopener">
					<div class="featured-seam" aria-hidden="true"></div>
					<div class="featured-body">
						<span class="featured-role">Co-founder &amp; CEO · 2021—</span>
						<h2>PolicyEngine</h2>
						<p>
							Free, open-source software that computes taxes and benefits for
							any household and simulates reforms across whole populations.
							Policymakers, researchers, and benefit navigators use it in the
							US, UK, and Canada.
						</p>
						<span class="featured-link">policyengine.org →</span>
					</div>
					<div class="featured-logo">
						<img src="/assets/logos/policyengine-teal.svg" alt="" width="72" height="72" />
					</div>
				</a>

				<div class="work-grid">
					{work.map((item) => (
						<a
							href={item.href}
							class="work-card"
							target={item.href.startsWith('http') ? '_blank' : undefined}
							rel={item.href.startsWith('http') ? 'noopener' : undefined}
						>
							<span class={`work-tag ${item.pole === 'rule' ? 'rule-tag' : 'cast-tag'}`}>{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>

				<a href="/projects" class="more-link">All projects →</a>
			</section>

			<!-- Writing -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Writing</span>
				</div>
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-row">
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							<span class="post-body">
								<span class="post-title">{post.data.title}</span>
								<span class="post-desc">{post.data.description}</span>
							</span>
						</a>
					))}
				</div>
				<a href="/blog" class="more-link">All writing →</a>
			</section>

			<!-- Research -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Research</span>
				</div>
				<div class="post-list">
					{research.map((paper) => (
						<a
							href={paper.href}
							class="post-row"
							target={paper.href.startsWith('http') ? '_blank' : undefined}
							rel={paper.href.startsWith('http') ? 'noopener' : undefined}
						>
							<span class="post-date research-date">{paper.date}</span>
							<span class="post-body">
								<span class="post-title">{paper.title}</span>
								<span class="post-desc">{paper.description}</span>
							</span>
						</a>
					))}
				</div>
				<a href="/projects#research" class="more-link">All research →</a>
			</section>

			<!-- Subscribe -->
			<section class="subscribe">
				<p class="subscribe-copy">Occasional notes on policy, code, and probability.</p>
				<form
					action={NEWSLETTER_URL}
					method="post"
					target="popupwindow"
					class="subscribe-form"
				>
					<input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
					<button type="submit">Subscribe</button>
				</form>
				<a href="/rss.xml" class="subscribe-rss">or RSS</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero */
	.hero {
		padding: 4.5rem 0 3rem;
		max-width: 780px;
	}

	.hero-title {
		font-size: clamp(2.4rem, 5.4vw, 3.9rem);
		font-weight: 500;
		line-height: 1.12;
		margin-bottom: 1.5rem;
	}

	.u-rule,
	.u-cast,
	.u-want {
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
	}

	.u-rule { text-decoration-color: var(--rule); }
	.u-cast { text-decoration-color: var(--cast); }
	.u-want { text-decoration-color: var(--ink); }

	.hero-sub {
		font-size: 1.15rem;
		line-height: 1.65;
		color: var(--ink-soft);
		max-width: 620px;
		margin-bottom: 1.75rem;
	}

	.hero-meta {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		margin-bottom: 2rem;
	}

	.hero-photo {
		width: 46px;
		height: 46px;
		border-radius: var(--radius-full);
		object-fit: cover;
		border: 1px solid var(--line);
	}

	.hero-role {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--ink-muted);
		letter-spacing: 0.01em;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.375rem;
		background: var(--ink);
		color: var(--paper);
		font-weight: 500;
		font-size: 0.9375rem;
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.btn-primary:hover {
		background: #3b342b;
		color: var(--paper);
		transform: translateY(-1px);
	}

	.btn-quiet {
		font-weight: 500;
		font-size: 0.9375rem;
		color: var(--ink-soft);
	}

	.btn-quiet:hover {
		color: var(--rule-deep);
	}

	/* The three poles */
	.poles-strip {
		margin: 2.75rem 0 5rem;
	}

	.poles {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		padding: 0 4px;
	}

	.pole {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.pole-right {
		text-align: right;
		align-items: flex-end;
	}

	.pole-mid {
		text-align: center;
		align-items: center;
	}

	.pole-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.rule-tag { color: var(--rule-deep); }
	.cast-tag { color: var(--cast-deep); }
	.want-tag { color: var(--ink); }

	.pole-tag.rule-tag::before,
	.pole-tag.cast-tag::before,
	.pole-tag.want-tag::before {
		content: '';
		width: 14px;
		height: 2.5px;
		border-radius: 1px;
	}

	.pole-tag.rule-tag::before { background: var(--rule); }
	.pole-tag.cast-tag::before { background: var(--cast); }
	.pole-tag.want-tag::before { background: var(--ink); }

	.pole-right .pole-tag { flex-direction: row-reverse; }

	.pole-copy {
		font-size: 0.875rem;
		color: var(--ink-muted);
	}

	/* Sections */
	.section {
		margin-bottom: 5rem;
	}

	.section-head {
		margin-bottom: 1.75rem;
	}

	/* Featured PolicyEngine card */
	.featured {
		position: relative;
		display: flex;
		align-items: center;
		gap: 2rem;
		padding: 2rem 2.25rem 2rem 2.5rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		overflow: hidden;
		transition: all var(--duration-normal) var(--ease-out);
		box-shadow: var(--shadow-sm);
		margin-bottom: 1.5rem;
	}

	.featured:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-2px);
	}

	.featured-seam {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: var(--seam-vertical);
	}

	/* Axiom sits on the rules pole; PolicyEngine keeps the full seam */
	.featured-seam.featured-rule {
		background: var(--rule);
	}

	.featured-body {
		flex: 1;
	}

	.featured-role {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink-muted);
		display: block;
		margin-bottom: 0.5rem;
	}

	.featured h2 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.featured p {
		color: var(--ink-soft);
		max-width: 640px;
		margin-bottom: 0.875rem;
	}

	.featured-link {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--rule-deep);
	}

	.featured:hover .featured-link {
		color: var(--rule);
	}

	.featured-logo {
		flex-shrink: 0;
		width: 96px;
		height: 96px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--paper-deep);
		border-radius: var(--radius-lg);
		padding: 1.125rem;
	}

	.featured-logo img {
		width: 100%;
		height: auto;
	}

	/* Work grid */
	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
		margin-bottom: 1.75rem;
	}

	.work-card {
		display: flex;
		flex-direction: column;
		padding: 1.375rem 1.5rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.work-card:hover {
		border-color: #d9d2c2;
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.work-tag {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		margin-bottom: 0.75rem;
	}

	.work-card h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.375rem;
		color: var(--ink);
	}

	.work-card p {
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
	}

	.more-link {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--ink-soft);
		transition: color var(--duration-fast) var(--ease-out);
	}

	.more-link:hover {
		color: var(--rule-deep);
	}

	/* Post / research lists */
	.post-list {
		display: flex;
		flex-direction: column;
		margin-bottom: 1.5rem;
	}

	.post-row {
		display: grid;
		grid-template-columns: 108px 1fr;
		gap: 1.5rem;
		padding: 1.125rem 0.25rem;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.post-row:first-child {
		border-top: 1px solid var(--line);
	}

	.post-row:hover {
		background: rgba(33, 29, 24, 0.02);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--ink-muted);
		padding-top: 0.3rem;
		white-space: nowrap;
	}

	.research-date {
		color: var(--cast-deep);
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--ink);
		line-height: 1.3;
	}

	.post-row:hover .post-title {
		color: var(--rule-deep);
	}

	.post-desc {
		font-size: 0.9rem;
		color: var(--ink-soft);
		line-height: 1.55;
	}

	/* Subscribe */
	.subscribe {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
		padding: 1.75rem 0.25rem;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.subscribe-copy {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		flex: 1;
		min-width: 260px;
	}

	.subscribe-form {
		display: flex;
		gap: 0.625rem;
	}

	.subscribe-form input {
		width: 230px;
		padding: 0.625rem 0.875rem;
		font-family: var(--font-body);
		font-size: 0.9rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		color: var(--ink);
	}

	.subscribe-form input:focus {
		outline: none;
		border-color: var(--mist);
	}

	.subscribe-form button {
		padding: 0.625rem 1.125rem;
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-weight: 500;
		background: var(--ink);
		color: var(--paper);
		border: none;
		border-radius: var(--radius-md);
		cursor: pointer;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.subscribe-form button:hover {
		background: #3b342b;
	}

	.subscribe-rss {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--ink-muted);
	}

	.subscribe-rss:hover {
		color: var(--rule-deep);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.work-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.hero {
			padding: 2.5rem 0 2rem;
		}

		.title-break {
			display: none;
		}

		.poles-strip {
			margin: 1.5rem 0 3.5rem;
		}

		.poles {
			flex-direction: column;
			gap: 0.875rem;
		}

		.pole-right,
		.pole-mid {
			text-align: left;
			align-items: flex-start;
		}

		.pole-right .pole-tag {
			flex-direction: row;
		}

		.featured {
			flex-direction: column;
			align-items: flex-start;
			padding: 1.75rem 1.5rem 1.75rem 1.75rem;
		}

		.featured-logo {
			order: -1;
			width: 64px;
			height: 64px;
			padding: 0.75rem;
		}

		.work-grid {
			grid-template-columns: 1fr;
		}

		.post-row {
			grid-template-columns: 1fr;
			gap: 0.375rem;
		}

		.post-date {
			padding-top: 0;
		}

		.section {
			margin-bottom: 3.5rem;
		}

		.subscribe {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>

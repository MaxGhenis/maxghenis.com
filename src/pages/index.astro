---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL_LINKS, NEWSLETTER_URL } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);

const work = [
	{
		title: 'PolicyBench',
		href: 'https://policybench.org',
		description: 'Open benchmark scoring AI models on tax and benefit law, graded against exact calculations.',
		tag: 'AI eval',
		pole: 'cast',
	},
	{
		title: 'populace',
		href: 'https://populace.dev',
		description: 'Calibrated survey microdata for policy simulation — national to local, fully reproducible.',
		tag: 'Microdata',
		pole: 'cast',
	},
	{
		title: 'HiveSight',
		href: 'https://hivesight.ai',
		description: 'Estimates public opinion by segment, grounding language models in survey microdata.',
		tag: 'Opinion',
		pole: 'cast',
	},
	{
		title: "MacKenzie Scott's giving, in QALYs",
		href: '/mackenzie-scott-qaly',
		description: "GiveWell-style Monte Carlo model of $26.3B in giving, running entirely in your browser.",
		tag: 'Monte Carlo',
		pole: 'cast',
	},
	{
		title: 'microdf',
		href: 'https://github.com/PolicyEngine/microdf',
		description: "Pandas extensions for weighted survey microdata, used across PolicyEngine's models.",
		tag: 'Python',
		pole: 'rule',
	},
	{
		title: 'TerminalGrid',
		href: '/terminalgrid',
		description: 'VS Code extension for keyboard-driven terminal grids, built for agentic coding.',
		tag: 'VS Code',
		pole: 'rule',
	},
];

const research = [
	{
		title: 'Enhancing survey microdata with administrative records',
		href: 'https://github.com/PolicyEngine/policyengine-us-data/blob/main/paper/main.pdf',
		description: 'Microsimulation dataset construction. Presented at NTA 2024.',
		date: '2024',
	},
	{
		title: 'What can LLMs tell us about the ETI?',
		href: 'https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5410643',
		description: 'With Jason DeBacker. How language models perceive behavioral responses to tax policy.',
		date: '2025',
	},
	{
		title: 'Can LLMs forecast human value evolution?',
		href: '/value-forecasting/',
		description: 'Testing model predictions of value change against the General Social Survey.',
		date: '2025',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero">
				<h1 class="hero-title">
					Simulating futures<br class="title-break" />
					to build the one we want.
				</h1>
				<p class="hero-sub">
					I'm Max Ghenis. I build open-source software that
					<span class="u-rule">computes what the law says</span>,
					<span class="u-cast">forecasts what will happen</span>, and
					<span class="u-want">estimates what people value</span>.
				</p>
				<div class="hero-meta">
					<img src="/images/headshot.png" alt="Max Ghenis" class="hero-photo" />
					<span class="hero-role">Co-founder &amp; CEO, PolicyEngine · Washington, DC</span>
				</div>
				<div class="hero-actions">
					<a href={`mailto:${SOCIAL_LINKS.email}`} class="btn-primary">Get in touch</a>
					<a href="/projects" class="btn-quiet">See the work →</a>
				</div>
			</section>

			<!-- Signature chart: rules left of now, forecasts right, one path chosen -->
			<section class="seamchart" aria-label="Chart metaphor: enacted policy as a step function up to now, then a fan of forecast paths after it, with one chosen path drawn through the fan.">
				<svg viewBox="0 0 1160 312" preserveAspectRatio="none" role="img" aria-hidden="true" class="seamchart-svg">
					<defs>
						<linearGradient id="seamV" x1="0" y1="0" x2="0" y2="1">
							<stop offset="0%" stop-color="#b45309" />
							<stop offset="38%" stop-color="#bf8a64" />
							<stop offset="62%" stop-color="#b08aa0" />
							<stop offset="100%" stop-color="#a94e80" />
						</linearGradient>
					</defs>

					<!-- grid -->
					<g class="grid" stroke="#e8e3d8" stroke-width="1">
						<line x1="20" y1="64" x2="1140" y2="64" />
						<line x1="20" y1="124" x2="1140" y2="124" />
						<line x1="20" y1="184" x2="1140" y2="184" />
						<line x1="20" y1="244" x2="1140" y2="244" />
					</g>

					<!-- the seam: now -->
					<line class="seam-line" x1="580" y1="18" x2="580" y2="272" stroke="url(#seamV)" stroke-width="1.5" opacity="0.55" vector-effect="non-scaling-stroke" />

					<!-- past: rules as a step function -->
					<path
						class="step-path"
						d="M 20,238 H 130 V 208 H 240 V 218 H 350 V 178 H 460 V 158 H 520 V 138 H 580"
						fill="none"
						stroke="#b45309"
						stroke-width="2.5"
						stroke-linejoin="miter"
						vector-effect="non-scaling-stroke"
					/>

					<!-- future: forecasts as a fan -->
					<g class="fan">
						<path
							d="M 580,138 Q 830,104 1140,54 L 1140,266 Q 830,186 580,138 Z"
							fill="#9fb6c6"
							opacity="0.20"
						/>
						<path
							d="M 580,138 Q 830,118 1140,96 L 1140,188 Q 830,158 580,138 Z"
							fill="#a94e80"
							opacity="0.14"
						/>
						<path
							class="median-path"
							d="M 580,138 Q 840,132 1140,122"
							fill="none"
							stroke="#a94e80"
							stroke-width="2.5"
							stroke-dasharray="2 7"
							stroke-linecap="round"
							vector-effect="non-scaling-stroke"
						/>
						<circle cx="1140" cy="122" r="9" fill="#a94e80" opacity="0.16" />
						<circle cx="1140" cy="122" r="4.5" fill="#a94e80" />
					</g>

					<!-- the chosen path through the fan -->
					<g class="choice">
						<path
							class="choice-path"
							d="M 580,138 Q 850,124 1140,100"
							fill="none"
							stroke="#211d18"
							stroke-width="2.5"
							stroke-linecap="round"
							vector-effect="non-scaling-stroke"
						/>
						<circle class="choice-dot" cx="1140" cy="100" r="4.5" fill="#211d18" />
						<text class="choice-label" x="1122" y="84" font-family="'JetBrains Mono', monospace" font-size="11" fill="#211d18" text-anchor="end">the one we want</text>
					</g>

					<!-- axis -->
					<g class="ticks" font-family="'JetBrains Mono', monospace" font-size="11" fill="#7d766c" text-anchor="middle">
						<text x="130" y="300">2014</text>
						<text x="350" y="300">2020</text>
						<text x="580" y="300" fill="#211d18" font-weight="500">now</text>
						<text x="860" y="300">2032</text>
						<text x="1140" y="300">2038</text>
					</g>
				</svg>

				<div class="poles">
					<div class="pole">
						<span class="pole-tag rule-tag">Rules</span>
						<span class="pole-copy">what the law says — exact, cited, computable</span>
					</div>
					<div class="pole pole-mid">
						<span class="pole-tag cast-tag">Forecasts</span>
						<span class="pole-copy">what will happen — probabilistic, scored, revisable</span>
					</div>
					<div class="pole pole-right">
						<span class="pole-tag want-tag">Choice</span>
						<span class="pole-copy">the one we want — decided, then built</span>
					</div>
				</div>
			</section>

			<!-- Work -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Work</span>
				</div>

				<a href="https://policyengine.org" class="featured" target="_blank" rel="noopener">
					<div class="featured-seam" aria-hidden="true"></div>
					<div class="featured-body">
						<span class="featured-role">Co-founder &amp; CEO · 2021—</span>
						<h2>PolicyEngine</h2>
						<p>
							Free, open-source software that computes taxes and benefits for
							any household and simulates reforms across whole populations.
							Policymakers, researchers, and benefit navigators use it in the
							US, UK, and Canada.
						</p>
						<span class="featured-link">policyengine.org →</span>
					</div>
					<div class="featured-logo">
						<img src="/assets/logos/policyengine-teal.svg" alt="" width="72" height="72" />
					</div>
				</a>

				<div class="work-grid">
					{work.map((item) => (
						<a
							href={item.href}
							class="work-card"
							target={item.href.startsWith('http') ? '_blank' : undefined}
							rel={item.href.startsWith('http') ? 'noopener' : undefined}
						>
							<span class={`work-tag ${item.pole === 'rule' ? 'rule-tag' : 'cast-tag'}`}>{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>

				<a href="/projects" class="more-link">All projects →</a>
			</section>

			<!-- Writing -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Writing</span>
				</div>
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-row">
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							<span class="post-body">
								<span class="post-title">{post.data.title}</span>
								<span class="post-desc">{post.data.description}</span>
							</span>
						</a>
					))}
				</div>
				<a href="/blog" class="more-link">All writing →</a>
			</section>

			<!-- Research -->
			<section class="section">
				<div class="section-head">
					<span class="eyebrow">Research</span>
				</div>
				<div class="post-list">
					{research.map((paper) => (
						<a
							href={paper.href}
							class="post-row"
							target={paper.href.startsWith('http') ? '_blank' : undefined}
							rel={paper.href.startsWith('http') ? 'noopener' : undefined}
						>
							<span class="post-date research-date">{paper.date}</span>
							<span class="post-body">
								<span class="post-title">{paper.title}</span>
								<span class="post-desc">{paper.description}</span>
							</span>
						</a>
					))}
				</div>
				<a href="/projects#research" class="more-link">All research →</a>
			</section>

			<!-- Subscribe -->
			<section class="subscribe">
				<p class="subscribe-copy">Occasional notes on policy, code, and probability.</p>
				<form
					action={NEWSLETTER_URL}
					method="post"
					target="popupwindow"
					class="subscribe-form"
				>
					<input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
					<button type="submit">Subscribe</button>
				</form>
				<a href="/rss.xml" class="subscribe-rss">or RSS</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Hero */
	.hero {
		padding: 4.5rem 0 3rem;
		max-width: 780px;
	}

	.hero-title {
		font-size: clamp(2.4rem, 5.4vw, 3.9rem);
		font-weight: 500;
		line-height: 1.12;
		margin-bottom: 1.5rem;
	}

	.u-rule,
	.u-cast,
	.u-want {
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
	}

	.u-rule { text-decoration-color: var(--rule); }
	.u-cast { text-decoration-color: var(--cast); }
	.u-want { text-decoration-color: var(--ink); }

	.hero-sub {
		font-size: 1.15rem;
		line-height: 1.65;
		color: var(--ink-soft);
		max-width: 620px;
		margin-bottom: 1.75rem;
	}

	.hero-meta {
		display: flex;
		align-items: center;
		gap: 0.875rem;
		margin-bottom: 2rem;
	}

	.hero-photo {
		width: 46px;
		height: 46px;
		border-radius: var(--radius-full);
		object-fit: cover;
		border: 1px solid var(--line);
	}

	.hero-role {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--ink-muted);
		letter-spacing: 0.01em;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.375rem;
		background: var(--ink);
		color: var(--paper);
		font-weight: 500;
		font-size: 0.9375rem;
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.btn-primary:hover {
		background: #3b342b;
		color: var(--paper);
		transform: translateY(-1px);
	}

	.btn-quiet {
		font-weight: 500;
		font-size: 0.9375rem;
		color: var(--ink-soft);
	}

	.btn-quiet:hover {
		color: var(--rule-deep);
	}

	/* Signature chart */
	.seamchart {
		margin: 1.5rem 0 5rem;
	}

	.seamchart-svg {
		width: 100%;
		height: auto;
		display: block;
	}

	.poles {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		margin-top: 0.75rem;
		padding: 0 4px;
	}

	.pole {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.pole-right {
		text-align: right;
		align-items: flex-end;
	}

	.pole-mid {
		text-align: center;
		align-items: center;
	}

	.pole-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.rule-tag { color: var(--rule-deep); }
	.cast-tag { color: var(--cast-deep); }
	.want-tag { color: var(--ink); }

	.pole-tag.rule-tag::before,
	.pole-tag.cast-tag::before,
	.pole-tag.want-tag::before {
		content: '';
		width: 14px;
		height: 2.5px;
		border-radius: 1px;
	}

	.pole-tag.rule-tag::before { background: var(--rule); }
	.pole-tag.cast-tag::before { background: var(--cast); }
	.pole-tag.want-tag::before { background: var(--ink); }

	.pole-right .pole-tag { flex-direction: row-reverse; }

	.pole-copy {
		font-size: 0.875rem;
		color: var(--ink-muted);
	}

	/* Chart animation */
	@media (prefers-reduced-motion: no-preference) {
		.step-path {
			stroke-dasharray: 1400;
			stroke-dashoffset: 1400;
			animation: drawstep 1.2s var(--ease-out) 0.25s forwards;
		}

		.fan {
			opacity: 0;
			animation: fadeIn 0.9s var(--ease-out) 1.15s forwards;
		}

		.seam-line {
			opacity: 0;
			animation: seamIn 0.6s var(--ease-out) 0.9s forwards;
		}

		.choice-path {
			stroke-dasharray: 620;
			stroke-dashoffset: 620;
			animation: drawstep 0.9s var(--ease-out) 2s forwards;
		}

		.choice-dot,
		.choice-label {
			opacity: 0;
			animation: fadeIn 0.5s var(--ease-out) 2.7s forwards;
		}
	}

	@keyframes drawstep {
		to { stroke-dashoffset: 0; }
	}

	@keyframes seamIn {
		to { opacity: 0.55; }
	}

	/* Sections */
	.section {
		margin-bottom: 5rem;
	}

	.section-head {
		margin-bottom: 1.75rem;
	}

	/* Featured PolicyEngine card */
	.featured {
		position: relative;
		display: flex;
		align-items: center;
		gap: 2rem;
		padding: 2rem 2.25rem 2rem 2.5rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		overflow: hidden;
		transition: all var(--duration-normal) var(--ease-out);
		box-shadow: var(--shadow-sm);
		margin-bottom: 1.5rem;
	}

	.featured:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-2px);
	}

	.featured-seam {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: var(--seam-vertical);
	}

	.featured-body {
		flex: 1;
	}

	.featured-role {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink-muted);
		display: block;
		margin-bottom: 0.5rem;
	}

	.featured h2 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.featured p {
		color: var(--ink-soft);
		max-width: 640px;
		margin-bottom: 0.875rem;
	}

	.featured-link {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--rule-deep);
	}

	.featured:hover .featured-link {
		color: var(--rule);
	}

	.featured-logo {
		flex-shrink: 0;
		width: 96px;
		height: 96px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--paper-deep);
		border-radius: var(--radius-lg);
		padding: 1.125rem;
	}

	.featured-logo img {
		width: 100%;
		height: auto;
	}

	/* Work grid */
	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
		margin-bottom: 1.75rem;
	}

	.work-card {
		display: flex;
		flex-direction: column;
		padding: 1.375rem 1.5rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.work-card:hover {
		border-color: #d9d2c2;
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.work-tag {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		margin-bottom: 0.75rem;
	}

	.work-card h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.375rem;
		color: var(--ink);
	}

	.work-card p {
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
	}

	.more-link {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--ink-soft);
		transition: color var(--duration-fast) var(--ease-out);
	}

	.more-link:hover {
		color: var(--rule-deep);
	}

	/* Post / research lists */
	.post-list {
		display: flex;
		flex-direction: column;
		margin-bottom: 1.5rem;
	}

	.post-row {
		display: grid;
		grid-template-columns: 108px 1fr;
		gap: 1.5rem;
		padding: 1.125rem 0.25rem;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.post-row:first-child {
		border-top: 1px solid var(--line);
	}

	.post-row:hover {
		background: rgba(33, 29, 24, 0.02);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--ink-muted);
		padding-top: 0.3rem;
		white-space: nowrap;
	}

	.research-date {
		color: var(--cast-deep);
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--ink);
		line-height: 1.3;
	}

	.post-row:hover .post-title {
		color: var(--rule-deep);
	}

	.post-desc {
		font-size: 0.9rem;
		color: var(--ink-soft);
		line-height: 1.55;
	}

	/* Subscribe */
	.subscribe {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-wrap: wrap;
		padding: 1.75rem 0.25rem;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.subscribe-copy {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		flex: 1;
		min-width: 260px;
	}

	.subscribe-form {
		display: flex;
		gap: 0.625rem;
	}

	.subscribe-form input {
		width: 230px;
		padding: 0.625rem 0.875rem;
		font-family: var(--font-body);
		font-size: 0.9rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		color: var(--ink);
	}

	.subscribe-form input:focus {
		outline: none;
		border-color: var(--mist);
	}

	.subscribe-form button {
		padding: 0.625rem 1.125rem;
		font-family: var(--font-body);
		font-size: 0.9rem;

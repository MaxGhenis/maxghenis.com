---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import {
  AGGREGATE_CATEGORIES,
  AGGREGATE_TOTAL_LITERS,
  AGGREGATE_TOTAL_MULTIPLE_MAX,
  AGGREGATE_TOTAL_MULTIPLE_MIN,
  AI_2025_MAX_LITERS,
  AI_2025_MIN_LITERS,
  DRINKS_WITH_QUERIES,
  QUERIES_PER_DAY,
  WATER_PER_QUERY_ML,
  formatLiters,
  formatMultipleRange,
  roundToSigFigs,
} from '../lib/drinking-ai';

const QUERIES_PER_DROP = 1000;
const defaultDrink = DRINKS_WITH_QUERIES[0];
const chartMaxLiters = Math.max(...AGGREGATE_CATEGORIES.map((c) => c.totalWaterLiters));

const clientDrinks = DRINKS_WITH_QUERIES.map((d) => ({
  id: d.id,
  name: d.name,
  serving: d.serving,
  queries: roundToSigFigs(d.queries),
  drops: Math.max(1, Math.round(d.queries / QUERIES_PER_DROP)),
  usageLabel: d.usageLabel,
  waterLiters: d.waterLiters,
  formula: d.formula,
  scopeNote: d.scopeNote,
  sourceLabel: d.sourceLabel,
  sourceUrl: d.sourceUrl ?? null,
}));

const sourceCards = [
  {
    title: 'OpenAI / Sam Altman',
    detail: 'Average ChatGPT query: 0.34 Wh and 0.000085 gallons (0.32 mL) of water. June 10, 2025.',
    url: 'https://blog.samaltman.com/the-gentle-singularity',
  },
  {
    title: 'Google Cloud',
    detail: 'Median Gemini Apps text prompt: 0.24 Wh and 0.26 mL of water. 2025.',
    url: 'https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/',
  },
  {
    title: 'de Vries-Gao, Patterns',
    detail: 'Modeled global AI water footprint for 2025: 312.5–764.6 billion liters. 2026.',
    url: 'https://doi.org/10.1016/j.patter.2025.101430',
  },
  {
    title: 'Hoekstra 2008',
    detail: 'Beer: 75 L per 250 mL glass. Wine: 120 L per 125 mL glass.',
    url: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
  },
  {
    title: 'Water Footprint Network Report 16',
    detail: 'Orange juice: 170 L per 200 mL glass.',
    url: 'https://www.waterfootprint.org/resources/Report16Vol1.pdf',
  },
  {
    title: 'Water Footprint Network Report 39',
    detail: 'Sugar-containing carbonated beverage: 169–309 L per 0.5 L bottle; 99.7–99.8% of it in the supply chain.',
    url: 'https://www.waterfootprint.org/resources/Report39-WaterFootprintCarbonatedBeverage.pdf',
  },
  {
    title: 'Water Footprint Network definitions',
    detail: 'Water footprints sum green, blue, and grey water — volume comparisons, not local scarcity impacts.',
    url: 'https://www.waterfootprint.org/water-footprint-2/what-is-a-water-footprint/',
  },
  {
    title: 'spiritsEUROPE 2020',
    detail: 'One serving of spirit drink: about 18 L of water.',
    url: 'https://spirits.eu/upload/files/publications/CP.MI-165-2020-%20Farm2Glass%20Brochure%20-%2014%20May%202020.pdf',
  },
  {
    title: 'IBWA 2024 benchmarking',
    detail: 'Bottled water facilities: 1.39 L of water per liter bottled in 2022.',
    url: 'https://bottledwater.org/wp-content/uploads/2024/08/IBWA-Benchmarking-Executive-Summary_May-2024.pdf',
  },
  {
    title: 'NIAAA Surveillance Report 122',
    detail: 'US beer, wine, and spirits volumes for 2023.',
    url: 'https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf',
  },
  {
    title: 'USDA ERS fruit-juices table',
    detail: 'US orange juice: 707.9 million gallons in 2022.',
    url: 'https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123',
  },
  {
    title: 'IBWA 2026 progress report',
    detail: 'Preliminary 2025: 16.8 billion gallons of bottled water; per-capita 47.5 gal bottled water, 33.9 gal carbonated soft drinks.',
    url: 'https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf',
  },
  {
    title: 'Andy Masley',
    detail: '"Using ChatGPT is not bad for the environment" — the post that prompted this page.',
    url: 'https://andymasley.substack.com/p/individual-ai-use-is-not-bad-for',
  },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Drinking AI | ${SITE_TITLE}`}
			description="One beer's water footprint equals about 331,000 ChatGPT queries. Drinks converted into AI queries, and US drink categories compared with all of 2025's AI water use."
			image="/og/drinking-ai.png"
		/>
	</head>
	<body>
		<Header />
		<main class="drinking-ai-page">
			<div class="page-atmosphere" aria-hidden="true"></div>

			<section class="poster">
				<span class="section-kicker">Water arithmetic</span>
				<h1 class="poster-title">Drinking AI</h1>
				<p class="lede">
					Growing, brewing, and packaging one beer takes about as much water as
					<strong>331,000</strong> ChatGPT queries. Pick a drink below to convert its water
					footprint into queries — then see how whole US drink categories compare with
					everything AI drank in 2025.
				</p>
			</section>

			<section class="workspace animate-fade-in-up delay-100" aria-labelledby="calculator-heading">
				<h2 id="calculator-heading" class="sr-only">One drink in ChatGPT queries</h2>

				<div class="controls" role="group" aria-label="Drink selector">
					{clientDrinks.map((drink, index) => (
						<button
							type="button"
							class={`drink-button${index === 0 ? ' is-active' : ''}`}
							aria-pressed={index === 0 ? 'true' : 'false'}
							data-drink={drink.id}
						>
							<span class="drink-name">{drink.name}</span>
							<span class="drink-serving">{drink.serving}</span>
						</button>
					))}
				</div>

				<div class="result-grid">
					<section class="result-panel" aria-live="polite">
						<div class="result-label">One <span data-result-name>{defaultDrink.name.toLowerCase()}</span> ≈</div>
						<div class="result-number" data-result-number>{roundToSigFigs(defaultDrink.queries).toLocaleString()}</div>
						<div class="result-unit">average ChatGPT queries</div>
						<p class="result-usage">
							Enough water for {QUERIES_PER_DAY} questions a day for
							<strong data-result-usage>{defaultDrink.usageLabel}</strong>.
						</p>
					</section>

					<aside class="detail-rail">
						<div class="detail-item">
							<div class="detail-label">Water footprint</div>
							<div class="detail-value" data-result-water>{defaultDrink.waterLiters.toFixed(1)} liters</div>
							<p data-result-formula>{defaultDrink.formula}</p>
						</div>
						<div class="detail-item">
							<div class="detail-label">What's counted</div>
							<p class="detail-note" data-result-note>{defaultDrink.scopeNote}</p>
							<p class="detail-source">
								<a
									href={defaultDrink.sourceUrl}
									data-result-source-link
									target="_blank"
									rel="noopener"
								>{defaultDrink.sourceLabel}</a>
								<span class="is-hidden" data-result-source-text>{defaultDrink.sourceLabel}</span>
							</p>
						</div>
						<div class="detail-item ai-baseline">
							<div class="detail-label">AI baseline</div>
							<div class="detail-value">{WATER_PER_QUERY_ML.toFixed(2)} mL per query</div>
							<p>
								<a href="https://blog.samaltman.com/the-gentle-singularity" target="_blank" rel="noopener">OpenAI's published average</a>;
								<a href="https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/" target="_blank" rel="noopener">Google's Gemini median</a>
								is 0.26 mL.
							</p>
						</div>
					</aside>
				</div>

				<div class="dot-field-card">
					<div class="dot-field-header">
						<span class="dot-legend"><span class="dot-swatch" aria-hidden="true"></span>1 drop = {QUERIES_PER_DROP.toLocaleString()} queries</span>
						<span class="dot-count"><strong data-dot-count>{defaultDrink.queries >= QUERIES_PER_DROP ? Math.round(defaultDrink.queries / QUERIES_PER_DROP).toLocaleString() : '1'}</strong> drops</span>
					</div>
					<div class="dot-field" data-dot-field aria-hidden="true"></div>
				</div>
			</section>

			<section class="aggregate-section animate-fade-in-up delay-200" aria-labelledby="aggregate-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Aggregate view</span>
						<h2 id="aggregate-heading">A year of US drinks vs a year of global AI</h2>
					</div>
					<p class="workspace-note">
						A 2026 <a href="https://doi.org/10.1016/j.patter.2025.101430" target="_blank" rel="noopener">Patterns paper</a>
						models the water footprint of all AI systems worldwide at
						{formatLiters(AI_2025_MIN_LITERS)} to {formatLiters(AI_2025_MAX_LITERS)} in 2025.
						The bars share one linear scale.
					</p>
				</div>

				<div class="chart" data-chart role="img" aria-label={`Annual water footprints on one scale: global AI ${formatLiters(AI_2025_MIN_LITERS)} to ${formatLiters(AI_2025_MAX_LITERS)}; ${AGGREGATE_CATEGORIES.map((c) => `US ${c.name.toLowerCase()} ${formatLiters(c.totalWaterLiters)} (${formatMultipleRange(c.multipleMin, c.multipleMax)} AI)`).join('; ')}.`}>
					<div class="chart-row is-ai">
						<div class="chart-head">
							<span class="chart-name">All global AI <span class="chart-year">2025, modeled</span></span>
							<span class="chart-value">{formatLiters(AI_2025_MIN_LITERS)} – {formatLiters(AI_2025_MAX_LITERS)}</span>
						</div>
						<div class="chart-track">
							<div
								class="chart-bar ai-bar"
								style={`--w: ${(AI_2025_MAX_LITERS / chartMaxLiters) * 100}%`}
							>
								<div class="ai-bar-min" style={`width: ${(AI_2025_MIN_LITERS / AI_2025_MAX_LITERS) * 100}%`}></div>
							</div>
						</div>
						<p class="chart-meta">Solid: low estimate. Faded: high estimate. World total, all AI systems.</p>
					</div>

					{AGGREGATE_CATEGORIES.map((category) => (
						<div class="chart-row">
							<div class="chart-head">
								<span class="chart-name">
									US {category.name.toLowerCase()} <span class="chart-year">{category.year}</span>
								</span>
								<span class="chart-value">
									{formatLiters(category.totalWaterLiters)}
									<span class="chart-multiple">{formatMultipleRange(category.multipleMin, category.multipleMax)} AI</span>
								</span>
							</div>
							<div class="chart-track">
								<div
									class="chart-bar"
									style={`--w: ${(category.totalWaterLiters / chartMaxLiters) * 100}%`}
								></div>
							</div>
							<p class="chart-meta">
								{category.volumeNote} · {category.footprintNote} ·{' '}
								{category.sources.map((source, i) => (
									<>
										<a href={source.url} target="_blank" rel="noopener">{source.label}</a>{i < category.sources.length - 1 ? ', ' : ''}
									</>
								))}
							</p>
						</div>
					))}
				</div>

				<p class="chart-total">
					The five categories sum to {formatLiters(AGGREGATE_TOTAL_LITERS)} a year —
					{formatMultipleRange(AGGREGATE_TOTAL_MULTIPLE_MIN, AGGREGATE_TOTAL_MULTIPLE_MAX)} the AI range.
					The AI estimate covers the world; the drink totals cover the US only, so world
					drink totals would sit further right.
				</p>
			</section>

			<section class="methodology animate-fade-in-up delay-300" aria-labelledby="methodology-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Methodology</span>
						<h2 id="methodology-heading">What's measured, and what isn't</h2>
					</div>
				</div>
				<div class="methodology-grid">
					<div class="methodology-column">
						<h3>The per-query figure</h3>
						<p>
							<a href="https://blog.samaltman.com/the-gentle-singularity" target="_blank" rel="noopener">Sam Altman's June 10, 2025 post</a>
							puts an average ChatGPT query at 0.34 watt-hours and 0.000085 gallons of water —
							0.32 mL. That is a product-wide average across model variants and tool paths;
							OpenAI publishes no per-model figure.
							<a href="https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/" target="_blank" rel="noopener">Google's 2025 measurement</a>
							of a median Gemini Apps text prompt — 0.24 watt-hours, 0.26 mL — lands within
							25% of it.
						</p>
					</div>
					<div class="methodology-column">
						<h3>The AI annual figure</h3>
						<p>
							<a href="https://doi.org/10.1016/j.patter.2025.101430" target="_blank" rel="noopener">de Vries-Gao (Patterns, 2026)</a>
							models AI systems worldwide at 312.5–764.6 billion liters in 2025, built up from
							company data-center disclosures rather than a directly reported total. It covers
							the whole world; the drink bars cover the US only.
						</p>
					</div>
					<div class="methodology-column">
						<h3>Drink footprints</h3>
						<p>
							Beer, wine, juice, and soda use full
							<a href="https://www.waterfootprint.org/water-footprint-2/what-is-a-water-footprint/" target="_blank" rel="noopener">green, blue, and grey water footprints</a> —
							for soda, 99.7–99.8% of the footprint sits in the crop supply chain, and this page
							uses the low end of the published 169–309 L range. Bottled water uses a facility
							ratio (1.39 L per L) and tap water counts only the 355 mL in the glass, so those
							two rows understate relative to the crop-based ones. Footprints compare volumes,
							not local scarcity impacts.
						</p>
					</div>
					<div class="methodology-column">
						<h3>US volumes</h3>
						<p>
							Each category uses its latest public total: beer and wine from
							<a href="https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf" target="_blank" rel="noopener">NIAAA (2023)</a>,
							orange juice from
							<a href="https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123" target="_blank" rel="noopener">USDA ERS (2022)</a>,
							bottled water and soda from
							<a href="https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf" target="_blank" rel="noopener">IBWA's preliminary 2025 report</a>.
							IBWA publishes soda only per capita, so its total comes from the population
							implied by IBWA's own bottled-water pair (16.8B gallons ÷ 47.5 gal per person).
							<a href="https://andymasley.substack.com/p/individual-ai-use-is-not-bad-for" target="_blank" rel="noopener">Andy Masley's post</a>
							prompted the question.
						</p>
					</div>
				</div>
			</section>

			<section class="sources animate-fade-in-up delay-300" aria-labelledby="sources-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Sources</span>
						<h2 id="sources-heading">All linked</h2>
					</div>
				</div>
				<div class="source-list">
					{sourceCards.map((source) => (
						<a href={source.url} class="source-item" target="_blank" rel="noopener">
							<h3>{source.title}</h3>
							<p>{source.detail}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<script define:vars={{ clientDrinks }}>
			const drinkMap = Object.fromEntries(clientDrinks.map((drink) => [drink.id, drink]));
			const buttons = Array.from(document.querySelectorAll('.drink-button'));
			const nameEl = document.querySelector('[data-result-name]');
			const numberEl = document.querySelector('[data-result-number]');
			const usageEl = document.querySelector('[data-result-usage]');
			const waterEl = document.querySelector('[data-result-water]');
			const formulaEl = document.querySelector('[data-result-formula]');
			const noteEl = document.querySelector('[data-result-note]');
			const sourceLinkEl = document.querySelector('[data-result-source-link]');
			const sourceTextEl = document.querySelector('[data-result-source-text]');
			const dotFieldEl = document.querySelector('[data-dot-field]');
			const dotCountEl = document.querySelector('[data-dot-count]');

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			let currentQueries = drinkMap['beer'].queries;
			let numberFrame = null;
			let numberTimeout = null;

			function animateNumber(from, to) {
				if (numberFrame) cancelAnimationFrame(numberFrame);
				if (numberTimeout) clearTimeout(numberTimeout);
				const setFinal = () => {
					numberEl.textContent = to.toLocaleString();
				};
				if (reduceMotion || document.hidden || from === to) {
					setFinal();
					return;
				}
				const duration = 500;
				const start = performance.now();
				function tick(now) {
					const t = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - t, 3);
					numberEl.textContent = Math.round(from + (to - from) * eased).toLocaleString();
					if (t < 1) numberFrame = requestAnimationFrame(tick);
				}
				numberFrame = requestAnimationFrame(tick);
				// rAF pauses in hidden tabs; this guarantees the final value regardless.
				numberTimeout = setTimeout(setFinal, duration + 100);
			}

			function renderDots(drops) {
				dotFieldEl.replaceChildren();
				const fragment = document.createDocumentFragment();
				const perDotDelay = reduceMotion ? 0 : Math.min(900 / drops, 4);
				for (let i = 0; i < drops; i++) {
					const dot = document.createElement('span');
					dot.className = 'dot';
					if (perDotDelay > 0) dot.style.animationDelay = `${(i * perDotDelay).toFixed(1)}ms`;
					else dot.style.animation = 'none';
					fragment.appendChild(dot);
				}
				dotFieldEl.appendChild(fragment);
				dotCountEl.textContent = drops.toLocaleString();
			}

			function updateDrink(drinkId) {
				const drink = drinkMap[drinkId];
				if (!drink) return;

				nameEl.textContent = drink.name.toLowerCase();
				animateNumber(currentQueries, drink.queries);
				currentQueries = drink.queries;
				usageEl.textContent = drink.usageLabel;
				waterEl.textContent = `${drink.waterLiters.toFixed(1)} liters`;
				formulaEl.textContent = drink.formula;
				noteEl.textContent = drink.scopeNote;

				if (drink.sourceUrl) {
					sourceLinkEl.classList.remove('is-hidden');
					sourceLinkEl.setAttribute('href', drink.sourceUrl);
					sourceLinkEl.textContent = drink.sourceLabel;
					sourceTextEl.classList.add('is-hidden');
				} else {
					sourceLinkEl.classList.add('is-hidden');
					sourceLinkEl.removeAttribute('href');
					sourceTextEl.textContent = drink.sourceLabel;
					sourceTextEl.classList.remove('is-hidden');
				}

				renderDots(drink.drops);

				buttons.forEach((button) => {
					const isActive = button.dataset.drink === drinkId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});
			}

			buttons.forEach((button) => {
				button.addEventListener('click', () => updateDrink(button.dataset.drink));
			});

			renderDots(drinkMap['beer'].drops);

			// Bars start collapsed only when JS runs; they grow on first scroll into view.
			const chart = document.querySelector('[data-chart]');
			if (chart && !reduceMotion && !document.hidden && 'IntersectionObserver' in window) {
				const bars = Array.from(chart.querySelectorAll('.chart-bar'));
				bars.forEach((bar) => {
					bar.style.width = '0%';
				});
				const release = () => {
					bars.forEach((bar) => {
						bar.style.width = '';
					});
					observer.disconnect();
					clearTimeout(releaseTimeout);
				};
				const observer = new IntersectionObserver(
					(entries) => {
						if (entries.some((entry) => entry.isIntersecting)) release();
					},
					{ threshold: 0.25 },
				);
				observer.observe(chart);
				// Safety: never leave the chart collapsed (hidden tabs, odd viewports).
				const releaseTimeout = setTimeout(release, 4000);
			}
		</script>
	</body>
</html>

<style>
	/* ══════════════════════════════════════════════
	   DRINKING AI — editorial data poster
	   Cyan = AI queries. Amber = drinks.
	   ══════════════════════════════════════════════ */

	.drinking-ai-page {
		--water: #0891b2;
		--water-bright: #06b6d4;
		--water-deep: #164e63;
		--water-glow: rgba(8, 145, 178, 0.18);
		--water-subtle: rgba(8, 145, 178, 0.07);
		--glass: rgba(255, 255, 255, 0.72);
		--glass-border: rgba(15, 23, 42, 0.07);
		position: relative;
	}

	.page-atmosphere {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background:
			radial-gradient(ellipse 800px 600px at 18% 8%, rgba(8, 145, 178, 0.05), transparent 70%),
			radial-gradient(ellipse 600px 400px at 85% 55%, rgba(245, 158, 11, 0.04), transparent 70%);
	}

	.poster, .workspace, .aggregate-section, .methodology, .sources {
		position: relative;
		z-index: 1;
	}

	.section-kicker, .result-label, .detail-label, .chart-year, .dot-legend {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--water);
	}

	/* ─── Poster ─── */

	.poster {
		padding: 3rem 0 1rem;
		max-width: 52rem;
	}

	.poster-title {
		font-size: clamp(3.4rem, 8vw, 6.5rem);
		margin: 0.4rem 0 1.1rem;
		letter-spacing: -0.04em;
		background: linear-gradient(135deg, var(--ink) 0%, var(--water-deep) 60%, var(--water) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.lede {
		font-size: 1.18rem;
		line-height: 1.7;
		color: var(--ink-soft);
		max-width: 44rem;
	}

	/* ─── Calculator ─── */

	.workspace {
		padding-top: 1.5rem;
	}

	.controls {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-bottom: 1.4rem;
	}

	.drink-button {
		display: grid;
		gap: 0.1rem;
		padding: 0.7rem 1.05rem;
		border: 1.5px solid var(--glass-border);
		border-radius: var(--radius-lg);
		background: var(--glass);
		color: var(--ink-soft);
		cursor: pointer;
		text-align: left;
		font: inherit;
		transition:
			transform 180ms var(--ease-out),

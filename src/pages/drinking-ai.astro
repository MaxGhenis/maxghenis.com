---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const waterPerQueryGallons = 0.000085;
const litersPerGallon = 3.785411784;
const waterPerQueryMl = waterPerQueryGallons * litersPerGallon * 1000;
const aiWaterFootprint2025MinLiters = 312.5e9;
const aiWaterFootprint2025MaxLiters = 764.6e9;

const decimalFormatter = new Intl.NumberFormat('en-US', { maximumFractionDigits: 1 });

function formatCompactValue(value: number) {
	if (value >= 1e12) return `${decimalFormatter.format(value / 1e12)} trillion`;
	if (value >= 1e9) return `${decimalFormatter.format(value / 1e9)} billion`;
	if (value >= 1e6) return `${decimalFormatter.format(value / 1e6)} million`;
	return decimalFormatter.format(value);
}

function formatLiters(value: number) {
	return `${formatCompactValue(value)} liters`;
}

function formatGallons(value: number) {
	return `${formatCompactValue(value)} gallons`;
}

const drinks = [
	{
		id: 'beer',
		name: 'Beer',
		serving: '12 oz / 355 mL bottle or pint',
		waterLiters: 75 * (355 / 250),
		formula: '75 L per 250 mL glass scaled to a 355 mL serving',
		sourceLabel: 'Hoekstra 2008: beer uses 75 liters per 250 mL glass',
		sourceUrl: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
		note: 'Compared with the same amount of tap water, the result barely changes.',
	},
	{
		id: 'wine',
		name: 'Wine',
		serving: '5 oz / 148 mL pour',
		waterLiters: 120 * (148 / 125),
		formula: '120 L per 125 mL glass scaled to a 148 mL serving',
		sourceLabel: 'Hoekstra 2008: wine uses 120 liters per 125 mL glass',
		sourceUrl: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
		note: 'Compared with the same amount of tap water, the result barely changes.',
	},
	{
		id: 'cocktail',
		name: 'Cocktail',
		serving: 'One standard mixed drink',
		waterLiters: 18,
		formula: '18 L per serving',
		sourceLabel: 'spiritsEUROPE 2020: one serving of spirit drink uses 18 liters of water on average',
		sourceUrl: 'https://spirits.eu/upload/files/publications/CP.MI-165-2020-%20Farm2Glass%20Brochure%20-%2014%20May%202020.pdf',
		note: 'This remains the weakest drink source on the page: a public industry estimate rather than a government table.',
	},
	{
		id: 'orange-juice',
		name: 'Orange Juice',
		serving: '8 oz / 237 mL glass',
		waterLiters: 170 * (237 / 200),
		formula: '170 L per 200 mL glass scaled to a 237 mL serving',
		sourceLabel: 'Water Footprint Network Report 16: orange juice uses 170 liters per 200 mL glass',
		sourceUrl: 'https://www.waterfootprint.org/resources/Report16Vol1.pdf',
		note: 'This uses orange juice specifically, because that is the cleanest USDA national juice category I could match later in the aggregate section.',
	},
	{
		id: 'soda',
		name: 'Soda',
		serving: '12 oz / 355 mL can',
		waterLiters: 169 * (355 / 500),
		formula: 'Conservative low end of 169 L per 0.5 L PET bottle, scaled to a 355 mL can',
		sourceLabel: 'Water Footprint Network Report 39: soda runs 169 to 309 liters per 0.5 L bottle; this page uses the low end',
		sourceUrl: 'https://www.waterfootprint.org/resources/Report39-WaterFootprintCarbonatedBeverage.pdf',
		note: 'This is intentionally conservative. Sugar source and production route can push the footprint much higher.',
	},
	{
		id: 'bottled-water',
		name: 'Bottled Water',
		serving: '12 oz / 355 mL bottle',
		waterLiters: 1.39 * 0.355,
		formula: '1.39 L of water used per 1 L bottled water, scaled to a 355 mL serving',
		sourceLabel: 'IBWA 2024 benchmarking: bottled water facilities used 1.39 liters of water per liter bottled',
		sourceUrl: 'https://bottledwater.org/wp-content/uploads/2024/08/IBWA-Benchmarking-Executive-Summary_May-2024.pdf',
		note: 'This is a facility process-water ratio, including the product water itself.',
	},
	{
		id: 'tap-water',
		name: 'Tap Water',
		serving: '12 oz / 355 mL glass',
		waterLiters: 0.355,
		formula: 'The water in the glass itself: 355 mL = 0.355 L',
		sourceLabel: 'No external source needed: this is just the water in the glass',
		note: 'This is the direct water in the glass, not a treatment or distribution lifecycle estimate.',
	},
];

const drinksWithQueries = drinks.map((drink) => ({
	...drink,
	queryEquivalent: (drink.waterLiters * 1000) / waterPerQueryMl,
}));

const maxDrinkWaterLiters = Math.max(...drinksWithQueries.map((drink) => drink.waterLiters));

const beerGallons = 6_170_858_000;
const wineGallons = 887_990_000;
const orangeJuiceGallons = 707_900_000;
const bottledWaterGallons = 16_800_000_000;
const bottledWaterPerCapitaGallons = 47.5;
const sodaPerCapitaGallons = 33.9;
const beverageMarketPopulation = bottledWaterGallons / bottledWaterPerCapitaGallons;
const sodaGallons = beverageMarketPopulation * sodaPerCapitaGallons;

const aggregateCategories = [
	{
		id: 'aggregate-beer',
		name: 'Beer',
		year: '2023',
		totalWaterLiters: beerGallons * litersPerGallon * 300,
		volumeSummary: `Latest public total: ${formatGallons(beerGallons)} in 2023.`,
		footprintSummary: 'Footprint basis: 300 liters of water per liter of beer.',
		note: 'Uses the same beer-footprint source as the drink calculator.',
		sources: [
			{
				label: 'NIAAA 2023 U.S. volume table',
				url: 'https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf',
			},
			{
				label: 'Hoekstra 2008',
				url: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
			},
		],
	},
	{
		id: 'aggregate-wine',
		name: 'Wine',
		year: '2023',
		totalWaterLiters: wineGallons * litersPerGallon * 960,
		volumeSummary: `Latest public total: ${formatGallons(wineGallons)} in 2023.`,
		footprintSummary: 'Footprint basis: 960 liters of water per liter of wine.',
		note: 'Again, this uses the same per-glass footprint shown in the calculator.',
		sources: [
			{
				label: 'NIAAA 2023 U.S. volume table',
				url: 'https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf',
			},
			{
				label: 'Hoekstra 2008',
				url: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
			},
		],
	},
	{
		id: 'aggregate-orange-juice',
		name: 'Orange Juice',
		year: '2022',
		totalWaterLiters: orangeJuiceGallons * litersPerGallon * 850,
		volumeSummary: `Latest clean USDA total: ${formatGallons(orangeJuiceGallons)} in 2022.`,
		footprintSummary: 'Footprint basis: 850 liters of water per liter of orange juice.',
		note: 'USDA gives a clean orange-juice total, but not a comparably clean all-juice total that matches this footprint basis.',
		sources: [
			{
				label: 'USDA ERS orange juice CSV',
				url: 'https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123',
			},
			{
				label: 'Water Footprint Network Report 16',
				url: 'https://www.waterfootprint.org/resources/Report16Vol1.pdf',
			},
		],
	},
	{
		id: 'aggregate-soda',
		name: 'Soda',
		year: '2025',
		totalWaterLiters: sodaGallons * litersPerGallon * (169 / 0.5),
		volumeSummary: `Derived 2025 total: about ${formatGallons(sodaGallons)} from BMC preliminary bottled-water volume and carbonated-soft-drink per-capita use.`,
		footprintSummary: 'Conservative footprint basis: 169 liters per 0.5 L bottle, or 338 liters per liter.',
		note: 'This is a floor estimate for a hypothetical sugar-containing PET-bottle soda; the same report gives 309 liters per 0.5 L bottle at the high end.',
		sources: [
			{
				label: 'IBWA 2026 progress report',
				url: 'https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf',
			},
			{
				label: 'Water Footprint Network Report 39',
				url: 'https://www.waterfootprint.org/resources/Report39-WaterFootprintCarbonatedBeverage.pdf',
			},
		],
	},
	{
		id: 'aggregate-bottled-water',
		name: 'Bottled Water',
		year: '2025',
		totalWaterLiters: bottledWaterGallons * litersPerGallon * 1.39,
		volumeSummary: `Latest public preliminary total: ${formatGallons(bottledWaterGallons)} in 2025.`,
		footprintSummary: 'Facility basis: 1.39 liters of water used per liter bottled.',
		note: 'This is the one category here that stays below the low end of the 2025 AI range.',
		sources: [
			{
				label: 'IBWA 2026 progress report',
				url: 'https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf',
			},
			{
				label: 'IBWA 2024 benchmarking',
				url: 'https://bottledwater.org/wp-content/uploads/2024/08/IBWA-Benchmarking-Executive-Summary_May-2024.pdf',
			},
		],
	},
].map((category) => ({
	...category,
	isTotal: false,
	multipleOfAiLow: category.totalWaterLiters / aiWaterFootprint2025MaxLiters,
	multipleOfAiHigh: category.totalWaterLiters / aiWaterFootprint2025MinLiters,
}));

const aggregateTotalWaterLiters = aggregateCategories.reduce(
	(total, category) => total + category.totalWaterLiters,
	0,
);

const aggregateEntries = [
	...aggregateCategories,
	{
		id: 'aggregate-all',
		name: 'All tracked categories',
		year: 'Mixed latest public years',
		totalWaterLiters: aggregateTotalWaterLiters,
		multipleOfAiLow: aggregateTotalWaterLiters / aiWaterFootprint2025MaxLiters,
		multipleOfAiHigh: aggregateTotalWaterLiters / aiWaterFootprint2025MinLiters,
		volumeSummary:
			'Sums beer, wine, orange juice, soda, and bottled water from the cards above.',
		footprintSummary:
			'Uses the latest public total I could find for each category rather than forcing everything into one weaker source year.',
		note:
			'Tap water and cocktails stay in the calculator only, because I did not find equally clean national drinking-only tap-water or mixed-drink totals on the same footing.',
		isTotal: true,
		sources: [],
	},
];

const maxAggregateMultiple = Math.max(
	...aggregateEntries.map((entry) => entry.multipleOfAiHigh),
);

const sourceCards = [
	{
		title: 'OpenAI / Sam Altman',
		detail: 'June 10, 2025. Public average ChatGPT query: 0.34 Wh and 0.000085 gallons of water.',
		url: 'https://blog.samaltman.com/the-gentle-singularity',
	},
	{
		title: 'Google Cloud 2025',
		detail: 'A useful cross-check: Google estimates a median Gemini Apps text prompt at 0.24 Wh and 0.26 mL of water, close to OpenAI\'s 0.322 mL ChatGPT average.',
		url: 'https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/',
	},
	{
		title: 'OpenAI GPT-5 launch',
		detail: 'August 7, 2025. Useful for product routing context, but it does not publish a GPT-5-only water figure.',
		url: 'https://openai.com/index/introducing-gpt-5/',
	},
	{
		title: 'Hoekstra 2008',
		detail: 'Beer: 75 liters per 250 mL glass. Wine: 120 liters per 125 mL glass.',
		url: 'https://www.waterfootprint.org/resources/Hoekstra-2008-WaterfootprintFood.pdf',
	},
	{
		title: 'Water Footprint Network Report 16',
		detail: 'Orange juice: 170 liters per 200 mL glass. Apple juice: 190 liters per 200 mL glass.',
		url: 'https://www.waterfootprint.org/resources/Report16Vol1.pdf',
	},
	{
		title: 'Water Footprint Network Report 39',
		detail: 'Hypothetical sugar-containing carbonated beverage: 169 to 309 liters per 0.5 L PET bottle; 99.7-99.8% is supply-chain water footprint.',
		url: 'https://www.waterfootprint.org/resources/Report39-WaterFootprintCarbonatedBeverage.pdf',
	},
	{
		title: 'Water Footprint Network definitions',
		detail: 'Water footprints combine green, blue, and grey components, so they are volume comparisons rather than local scarcity-impact estimates.',
		url: 'https://www.waterfootprint.org/water-footprint-2/what-is-a-water-footprint/',
	},
	{
		title: 'spiritsEUROPE 2020',
		detail: 'One serving of spirit drink uses about 18 liters of water on average.',
		url: 'https://spirits.eu/upload/files/publications/CP.MI-165-2020-%20Farm2Glass%20Brochure%20-%2014%20May%202020.pdf',
	},
	{
		title: 'IBWA 2024 benchmarking',
		detail: 'Bottled water facilities used 1.39 liters of water per liter bottled in 2022.',
		url: 'https://bottledwater.org/wp-content/uploads/2024/08/IBWA-Benchmarking-Executive-Summary_May-2024.pdf',
	},
	{
		title: 'NIAAA Surveillance Report 122',
		detail: 'U.S. beer, wine, and spirits volumes in 2023.',
		url: 'https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf',
	},
	{
		title: 'USDA ERS fruit-juices CSV',
		detail: 'Latest clean public orange-juice total: 707.9 million gallons in 2022.',
		url: 'https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123',
	},
	{
		title: 'IBWA 2026 progress report',
		detail: 'Preliminary 2025 bottled water volume: 16.8 billion gallons. Per-capita use: 47.5 gallons for bottled water and 33.9 gallons for carbonated soft drinks.',
		url: 'https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf',
	},
	{
		title: 'Patterns 2026',
		detail: 'Freshest published AI-wide benchmark I found: AI systems alone could reach 312.5 to 764.6 billion liters of water in 2025.',
		url: 'https://www.sciencedirect.com/science/article/pii/S2666389925002788',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Drinking AI | ${SITE_TITLE}`}
			description="A calculator and aggregate view comparing beer, wine, juice, soda, bottled water, and tap water with average ChatGPT turns and a fresh 2025 AI water estimate."
			image="/og/drinking-ai.png"
		/>
	</head>
	<body>
		<Header />
		<main class="drinking-ai-page">
			<div class="page-atmosphere" aria-hidden="true"></div>
			<section class="poster">
				<div class="poster-copy">
					<h1 class="poster-title">Drinking AI</h1>
					<p class="lede">
						How many average ChatGPT turns does a drink "use" in water terms? This page now
						covers alcohol, juice, soda, bottled water, and tap water, then zooms out to show
						how whole U.S. drink categories compare with the freshest published 2025 AI water estimate I could find.
					</p>
				</div>
				<div class="poster-aside">
					<div class="aside-glow" aria-hidden="true"></div>
					<div class="aside-label">AI baseline</div>
					<div class="aside-value">0.322<span class="aside-unit">mL</span></div>
					<p>Average ChatGPT query water use from OpenAI's June 10, 2025 public estimate.</p>
				</div>
			</section>

			<section class="workspace animate-fade-in-up delay-100" aria-labelledby="calculator-heading">
				<div class="workspace-header">
					<div>
						<span class="section-kicker">Calculator</span>
						<h2 id="calculator-heading">Choose a drink</h2>
					</div>
					<p class="workspace-note">
						Most drink numbers use full water footprints. Bottled and tap water are different:
						they use process water or the water in the glass itself.
					</p>
				</div>

				<div class="controls" role="group" aria-label="Drink selector">
					{drinksWithQueries.map((drink, index) => (
						<button
							type="button"
							class={`drink-button${index === 0 ? ' is-active' : ''}`}
							aria-pressed={index === 0 ? 'true' : 'false'}
							data-drink={drink.id}
						>
							<span class="drink-name">{drink.name}</span>
							<span class="drink-serving">{drink.serving}</span>
						</button>
					))}
				</div>

				<div class="result-grid">
					<section id="result-panel" class="result-panel" tabindex="0" aria-live="polite">
						<div class="result-meter">
							<div class="meter-copy">
								<div class="result-label">Equivalent average ChatGPT turns</div>
								<div class="result-number" data-result-number>
									{Math.round(drinksWithQueries[0].queryEquivalent).toLocaleString()}
								</div>
								<p class="result-summary" data-result-summary>
									One {drinksWithQueries[0].serving.toLowerCase()} of {drinksWithQueries[0].name.toLowerCase()} is
									about {Math.round(drinksWithQueries[0].queryEquivalent).toLocaleString()} average ChatGPT turns.
								</p>
							</div>
							<div class="meter-visual" aria-hidden="true">
								<div class="meter-context">Relative footprint within this set of drinks</div>
								<div class="meter-track">
									<div class="meter-fill" data-meter-fill><div class="meter-wave" aria-hidden="true"></div></div>
								</div>
								<div class="meter-scale">
									<span>Lower</span>
									<span>Higher</span>
								</div>
							</div>
						</div>
					</section>

					<aside class="detail-rail">
						<div class="detail-item">
							<div class="detail-label">Drink water footprint</div>
							<div class="detail-value" data-result-water>
								{drinksWithQueries[0].waterLiters.toFixed(1)} liters
							</div>
							<p data-result-formula>{drinksWithQueries[0].formula}</p>
						</div>
						<div class="detail-item">
							<div class="detail-label">Context</div>
							<div class="detail-value">Read the caveat</div>
							<p data-result-note>{drinksWithQueries[0].note}</p>
						</div>
						<div class="detail-item">
							<div class="detail-label">Source</div>
							<div class="detail-value" data-result-source-title>
								{drinksWithQueries[0].sourceLabel}
							</div>
							<p>
								<a
									href={drinksWithQueries[0].sourceUrl}
									data-result-source-link
									target="_blank"
									rel="noopener"
								>
									Open source
								</a>
								<span class="is-hidden" data-result-source-text>No external source needed.</span>
							</p>
						</div>
					</aside>
				</div>
			</section>

			<section class="aggregate-section animate-fade-in-up delay-200" aria-labelledby="aggregate-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Aggregate view</span>
						<h2 id="aggregate-heading">How whole drink categories compare with 2025 AI</h2>
					</div>
					<p class="workspace-note">
						I dropped the old 2023 data-center baseline. This section now uses a January 9, 2026
						Patterns paper estimating that AI systems alone could reach 312.5 to 764.6 billion liters
						of water globally in 2025.
					</p>
				</div>

				<div class="aggregate-benchmark">
					<div class="aggregate-benchmark-card">
						<div class="detail-label">Fresh 2025 AI benchmark</div>
						<div class="aggregate-benchmark-value">
							{formatLiters(aiWaterFootprint2025MinLiters)} to {formatLiters(aiWaterFootprint2025MaxLiters)}
						</div>
						<p>Estimated total water footprint of AI systems alone in 2025.</p>
					</div>
					<div class="aggregate-benchmark-copy">
						<p>
							This is fresher and more AI-specific than the old 2023 all-data-center benchmark.
							It is still a modeled estimate built from company data-center disclosures rather
							than a directly reported AI water total.
						</p>
						<p>
							The tradeoff is geography: the AI benchmark is global, while the drink-category
							totals below are U.S. totals. I am using it for scale, not pretending it is a
							perfect apples-to-apples national comparison.
						</p>
						<p class="aggregate-benchmark-links">
							<a
								href="https://www.sciencedirect.com/science/article/pii/S2666389925002788"
								target="_blank"
								rel="noopener"
							>
								Open Patterns paper
							</a>
							<a
								href="https://doi.org/10.1016/j.patter.2025.101430"
								target="_blank"
								rel="noopener"
							>
								Open DOI
							</a>
						</p>
					</div>
				</div>

				<div class="aggregate-grid">
					{aggregateEntries.map((entry) => (
						<article class={`aggregate-card${entry.isTotal ? ' is-total' : ''}`}>
							<div class="aggregate-topline">
								<span class="aggregate-year">{entry.year}</span>
								<h3>{entry.name}</h3>
							</div>
							<div class="aggregate-multiple">
								{decimalFormatter.format(entry.multipleOfAiLow)}-{decimalFormatter.format(entry.multipleOfAiHigh)}x
							</div>
							<p class="aggregate-summary">
								About {decimalFormatter.format(entry.multipleOfAiLow)} to {decimalFormatter.format(entry.multipleOfAiHigh)}
								times 2025 AI's estimated total water footprint.
							</p>
							<div class="aggregate-bar" aria-hidden="true">
								<div
									class="aggregate-bar-fill"
									style={`width: ${Math.max(8, (entry.multipleOfAiHigh / maxAggregateMultiple) * 100)}%`}
								></div>
							</div>
							<div class="aggregate-water">{formatLiters(entry.totalWaterLiters)} per year</div>
							<p class="aggregate-meta">{entry.volumeSummary}</p>
							<p class="aggregate-meta">{entry.footprintSummary}</p>
							<p class="aggregate-meta">{entry.note}</p>
							{entry.sources.length > 0 && (
								<div class="aggregate-sources">
									{entry.sources.map((source) => (
										<a href={source.url} target="_blank" rel="noopener">
											{source.label}
										</a>
									))}
								</div>
							)}
						</article>
					))}
				</div>
			</section>

			<section class="methodology animate-fade-in-up delay-300">
				<div class="section-heading">
					<span class="section-kicker">Methodology</span>
					<h2>What is clean here, and what is not</h2>
				</div>
				<div class="methodology-grid">
					<div class="methodology-column">
						<p>
							The drink calculator still uses average ChatGPT turns, not GPT-5-only responses,
							because OpenAI has not published a GPT-5-only water-per-response figure. ChatGPT
							routes requests across model variants and tool paths, so the product-wide average
							is the cleanest public number.
						</p>
						<p>
							That benchmark comes from Sam Altman's June 10, 2025 post, which says an average
							ChatGPT query uses about 0.34 watt-hours and 0.000085 gallons of water. Converted,
							that is about 0.322 milliliters per average turn.
						</p>
						<p>
							Google's 2025 Gemini Apps measurement is a useful sanity check on the order of
							magnitude: it reports 0.24 watt-hours and 0.26 milliliters of water for a median
							text prompt. I do not substitute it for ChatGPT, but it makes the "fractions of a
							milliliter per prompt" scale less dependent on one company blog post.
						</p>
					</div>
					<div class="methodology-column">
						<p>
							For aggregate drink categories, I use the latest public total I could find for
							each category rather than pretending everything is available in one clean year.
							That means beer and wine are 2023, orange juice is 2022, and soda and bottled
							water use preliminary 2025 data.
						</p>
						<p>
							Andy Masley helped frame the question, but the page now points directly to
							government, NGO, first-party industry documents, and the newest peer-reviewed AI
							water estimate I could find. Soda is deliberately conservative, bottled water uses
							a facility ratio rather than a farm footprint, and cocktails remain the weakest
							source on the page.
						</p>
						<p>
							The main caveat is scope. Beer, wine, juice, and soda use full green, blue, and
							grey water-footprint accounting. Bottled water uses a facility water-use ratio.
							Tap water is only the water in the glass. The chart is a scale comparison, not a
							claim that every liter has the same local scarcity impact.
						</p>
					</div>
				</div>
			</section>

			<section class="sources animate-fade-in-up delay-300">
				<div class="section-heading">
					<span class="section-kicker">Sources</span>
					<h2>All linked</h2>
				</div>
				<div class="source-list">
					{sourceCards.map((source) => (
						<a href={source.url} class="source-item" target="_blank" rel="noopener">
							<h3>{source.title}</h3>
							<p>{source.detail}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<script define:vars={{ drinksWithQueries, maxDrinkWaterLiters }}>
			const drinkMap = Object.fromEntries(drinksWithQueries.map((drink) => [drink.id, drink]));
			const buttons = Array.from(document.querySelectorAll('.drink-button'));
			const numberEl = document.querySelector('[data-result-number]');
			const summaryEl = document.querySelector('[data-result-summary]');
			const waterEl = document.querySelector('[data-result-water]');
			const formulaEl = document.querySelector('[data-result-formula]');
			const noteEl = document.querySelector('[data-result-note]');
			const sourceTitleEl = document.querySelector('[data-result-source-title]');
			const sourceLinkEl = document.querySelector('[data-result-source-link]');
			const sourceTextEl = document.querySelector('[data-result-source-text]');
			const meterFillEl = document.querySelector('[data-meter-fill]');

			function updateDrink(drinkId) {
				const drink = drinkMap[drinkId];
				if (
					!drink ||
					!numberEl ||
					!summaryEl ||
					!waterEl ||
					!formulaEl ||
					!noteEl ||
					!sourceTitleEl ||
					!sourceLinkEl ||
					!sourceTextEl ||
					!meterFillEl
				) {
					return;
				}

				numberEl.textContent = Math.round(drink.queryEquivalent).toLocaleString();
				summaryEl.textContent = `One ${drink.serving.toLowerCase()} of ${drink.name.toLowerCase()} is about ${Math.round(drink.queryEquivalent).toLocaleString()} average ChatGPT turns.`;
				waterEl.textContent = `${drink.waterLiters.toFixed(1)} liters`;
				formulaEl.textContent = drink.formula;
				noteEl.textContent = drink.note;
				sourceTitleEl.textContent = drink.sourceLabel;

				if (drink.sourceUrl) {
					sourceLinkEl.classList.remove('is-hidden');
					sourceLinkEl.setAttribute('href', drink.sourceUrl);
					sourceTextEl.classList.add('is-hidden');
				} else {
					sourceLinkEl.classList.add('is-hidden');
					sourceLinkEl.removeAttribute('href');
					sourceTextEl.classList.remove('is-hidden');
				}

				meterFillEl.style.width = `${Math.max(12, (drink.waterLiters / maxDrinkWaterLiters) * 100)}%`;

				buttons.forEach((button) => {
					const isActive = button.dataset.drink === drinkId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});
			}

			buttons.forEach((button) => {
				button.addEventListener('click', () => updateDrink(button.dataset.drink));
			});

			updateDrink('beer');
		</script>
	</body>
</html>


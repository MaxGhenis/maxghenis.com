---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import {
  AGGREGATE_CATEGORIES,
  AGGREGATE_TOTAL_LITERS,
  AGGREGATE_TOTAL_MULTIPLE_2026_MAX,
  AGGREGATE_TOTAL_MULTIPLE_2026_MIN,
  AGGREGATE_TOTAL_MULTIPLE_MAX,
  AGGREGATE_TOTAL_MULTIPLE_MIN,
  AI_2025_MAX_LITERS,
  AI_2025_MIN_LITERS,
  AI_2026_MAX_LITERS,
  AI_2026_MIN_LITERS,
  AI_BENCHMARK_SOURCE,
  AI_POWER_GROWTH_2025_TO_2026,
  DEFAULT_SCOPE_ID,
  DEFAULT_WORKLOAD_ID,
  QUERIES_PER_DAY,
  QUERY_SCOPES,
  SCOPED_DRINKS,
  WORKLOAD_TIERS,
  dailyUseLabel,
  formatLiters,
  formatMultipleRange,
  roundToSigFigs,
} from '../lib/drinking-ai';

const QUERIES_PER_DROP = 1000;
const chartMaxLiters = Math.max(...AGGREGATE_CATEGORIES.map((c) => c.totalWaterLiters));

const clientDrinks = SCOPED_DRINKS.map((d) => {
  // One cell per (scope × workload) combination — both axes multiply the
  // water-per-unit, so a count is waterLiters / (scopeMl × workloadMultiple).
  const byCombo: Record<string, { count: number; drops: number; subDrop: boolean; usage: string }> = {};
  for (const s of QUERY_SCOPES) {
    for (const w of WORKLOAD_TIERS) {
      const perUnitMl = s.perQueryMl * w.multiple;
      const raw = (d.waterLiters * 1000) / perUnitMl;
      byCombo[`${s.id}:${w.id}`] = {
        count: roundToSigFigs(raw),
        drops: Math.max(1, Math.round(raw / QUERIES_PER_DROP)),
        // Rounds below one drop: shown as a single faded drop labeled "<1".
        subDrop: Math.round(raw / QUERIES_PER_DROP) === 0,
        usage: dailyUseLabel(raw),
      };
    }
  }
  // Default range: across accounting scopes at the default workload, so the unit
  // stays consistent (the client recomputes it when the workload changes).
  const defScopeCounts = QUERY_SCOPES.map((s) => byCombo[`${s.id}:${DEFAULT_WORKLOAD_ID}`].count);
  return {
    id: d.id,
    name: d.name,
    serving: d.serving,
    waterLiters: d.waterLiters,
    derivation: d.derivation,
    scopeNote: d.scopeNote,
    sources: d.sources,
    flagged: d.flagged ?? false,
    byCombo,
    rangeLow: Math.min(...defScopeCounts),
    rangeHigh: Math.max(...defScopeCounts),
  };
});

const clientScopes = QUERY_SCOPES.map((s) => ({
  id: s.id,
  label: s.label,
  boundary: s.boundary,
  perQueryMl: s.perQueryMl,
  detail: s.detail,
  sourceLabel: s.sourceLabel,
  sourceUrl: s.sourceUrl,
}));

const clientWorkloads = WORKLOAD_TIERS.map((w) => ({
  id: w.id,
  label: w.label,
  unit: w.unit,
  daily: w.daily,
  unitSingular: w.unitSingular,
  multiple: w.multiple,
  detail: w.detail,
  sourceLabel: w.sourceLabel,
  sourceUrl: w.sourceUrl,
  estimate: w.estimate ?? false,
}));

const defaultDrink = clientDrinks[0];
const defaultScope = clientScopes.find((s) => s.id === DEFAULT_SCOPE_ID) ?? clientScopes[0];
const defaultWorkload = clientWorkloads.find((w) => w.id === DEFAULT_WORKLOAD_ID) ?? clientWorkloads[0];
const defaultCell = defaultDrink.byCombo[`${defaultScope.id}:${defaultWorkload.id}`];
const defaultPerUnitMl = defaultScope.perQueryMl * defaultWorkload.multiple;

// Beer at the on-site scope, in each workload unit — for the "shift to agents" strip.
const heroBeer = clientDrinks.find((d) => d.id === 'beer') ?? clientDrinks[0];
const beerUnits = WORKLOAD_TIERS.map((w) => ({
  label: w.unit,
  multiple: w.multiple,
  count: heroBeer.byCombo[`onsite:${w.id}`].count,
}));

const sourceCards = [
  {
    group: 'AI water',
    title: 'OpenAI / Sam Altman',
    detail: 'Average ChatGPT query: 0.34 Wh and 0.000085 gallons (0.32 mL) of water. June 10, 2025.',
    url: 'https://blog.samaltman.com/the-gentle-singularity',
  },
  {
    group: 'AI water',
    title: 'Google Cloud',
    detail: 'Median Gemini Apps text prompt: 0.24 Wh and 0.26 mL of water, defined as data-center cooling only. 2025.',
    url: 'https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/',
  },
  {
    group: 'AI water',
    title: 'Jegham et al. 2025',
    detail: '"How hungry is AI?" Adds power-plant water: GPT-4o lands near 2 mL per query on an all-in operational basis.',
    url: 'https://arxiv.org/abs/2505.09598',
  },
  {
    group: 'AI water',
    title: 'Mistral AI',
    detail: 'ISO-reviewed life-cycle assessment: 45 mL of water per 400-token response from a large model. 2025.',
    url: 'https://mistral.ai/news/our-contribution-to-a-global-environmental-standard-for-ai',
  },
  {
    group: 'AI water',
    title: 'Li & Ren — "Making AI less thirsty"',
    detail: 'GPT-3 consumed roughly a 500 mL bottle per 10–50 responses; 2027 global AI withdrawal projected at 4.2–6.6 billion m³.',
    url: 'https://arxiv.org/abs/2304.03271',
  },
  {
    group: 'AI water',
    title: 'de Vries-Gao, Patterns 2026',
    detail: "AI's modeled global water footprint reaches 312.5–764.6 billion liters in 2025.",
    url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12827721/',
  },
  {
    group: 'AI water',
    title: 'LBNL 2024 data-center report',
    detail: 'US data centers consumed 17.4 billion gallons on-site in 2023, plus ~211 billion gallons via electricity.',
    url: 'https://eta-publications.lbl.gov/sites/default/files/2024-12/lbnl-2024-united-states-data-center-energy-usage-report_1.pdf',
  },
  {
    group: 'Workload & growth',
    title: 'Anthropic engineering',
    detail: 'Multi-agent systems used about 15x the tokens of a chat interaction; single agents about 4x.',
    url: 'https://www.anthropic.com/engineering/multi-agent-research-system',
  },
  {
    group: 'Workload & growth',
    title: 'Epoch AI',
    detail: 'A typical query is ~0.3 Wh; reasoning models emit ~2.5x the tokens; AI data-center power was ~30 GW in late 2025.',
    url: 'https://epoch.ai/gradient-updates/how-much-energy-does-chatgpt-use',
  },
  {
    group: 'Workload & growth',
    title: 'IEA — Energy and AI',
    detail: 'Data-center electricity 415 TWh (2024) to ~945 TWh by 2030; accelerated servers grow ~30% a year.',
    url: 'https://www.iea.org/reports/energy-and-ai',
  },
  {
    group: 'Workload & growth',
    title: 'UN University (UNU-INWEH)',
    detail: 'All data centers used ~4.5 trillion L of water in 2024/25 (AI ~20% of it), heading toward 9.3 trillion by 2030.',
    url: 'https://unu.edu/inweh/news/environmental-cost-of-AIs-Enrgy-use-carbon-water-and-land-footprints',
  },
  {
    group: 'Drink footprints',
    title: 'Mekonnen & Hoekstra 2011',
    detail: 'The canonical crop-water table: beer 298, wine 869, orange juice 1,018, coffee 18,925, tea 8,856 L/kg.',
    url: 'https://hess.copernicus.org/articles/15/1577/2011/hess-15-1577-2011.pdf',
  },
  {
    group: 'Drink footprints',
    title: 'Mekonnen & Hoekstra 2012',
    detail: 'Farm-animal products: milk at 1,020 liters of water per kg.',
    url: 'https://www.waterfootprint.org/resources/Mekonnen-Hoekstra-2012-WaterFootprintFarmAnimalProducts_1.pdf',
  },
  {
    group: 'Drink footprints',
    title: 'Chapagain & Hoekstra 2007',
    detail: 'The classic "140 liters per cup of coffee" study; 30–34 L per cup of tea.',
    url: 'https://ayhoekstra.nl/pubs/Chapagain-Hoekstra-2007.pdf',
  },
  {
    group: 'Drink footprints',
    title: 'Ercin, Aldaya & Hoekstra 2011',
    detail: 'Sugar-containing carbonated beverage: 169–309 liters per 0.5 L bottle; 99.7% in the supply chain.',
    url: 'https://ayhoekstra.nl/pubs/Ercin-et-al-2011.pdf',
  },
  {
    group: 'Drink footprints',
    title: 'IBWA 2024 benchmarking',
    detail: 'Bottled water facilities used 1.39 liters of water per liter bottled in 2022.',
    url: 'https://bottledwater.org/wp-content/uploads/2024/08/IBWA-Benchmarking-Executive-Summary_May-2024.pdf',
  },
  {
    group: 'Drink footprints',
    title: 'spiritsEUROPE 2020',
    detail: 'Industry figure: about 18 liters of water per serving of spirits. Not peer-reviewed.',
    url: 'https://spirits.eu/upload/files/publications/CP.MI-165-2020-%20Farm2Glass%20Brochure%20-%2014%20May%202020.pdf',
  },
  {
    group: 'US volumes',
    title: 'NIAAA Surveillance Report 122',
    detail: 'US beer (6.17B gal) and wine (0.89B gal) volumes, 2023.',
    url: 'https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf',
  },
  {
    group: 'US volumes',
    title: 'USDA ERS fruit-juices table',
    detail: 'US orange juice: 747.4 million gallons in 2021, the latest year in the series.',
    url: 'https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123',
  },
  {
    group: 'US volumes',
    title: 'USDA ERS dairy data',
    detail: 'US fluid milk sales: 43.2 billion pounds in 2024.',
    url: 'https://www.ers.usda.gov/data-products/dairy-data/',
  },
  {
    group: 'US volumes',
    title: 'USDA FAS coffee report',
    detail: 'US green-coffee consumption: 26.2 million 60-kg bags in 2024/25.',
    url: 'https://apps.fas.usda.gov/psdonline/circulars/coffee.pdf',
  },
  {
    group: 'US volumes',
    title: 'Tea Association of the USA',
    detail: 'Americans drank about 86 billion servings of tea in 2023.',
    url: 'https://www.teausa.org/tea-fact-sheet',
  },
  {
    group: 'US volumes',
    title: 'IBWA 2026 progress report',
    detail: 'Preliminary 2025: 16.8 billion gallons of bottled water; per-capita 47.5 gal water, 33.9 gal soda.',
    url: 'https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf',
  },
  {
    group: 'Context',
    title: 'Andy Masley',
    detail: '"Using ChatGPT is not bad for the environment" — the post that prompted this page.',
    url: 'https://andymasley.substack.com/p/individual-ai-use-is-not-bad-for',
  },
];

const sourceGroups = ['AI water', 'Workload & growth', 'Drink footprints', 'US volumes', 'Context'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Drinking AI | ${SITE_TITLE}`}
			description="One beer's water footprint equals about 331,000 ChatGPT queries. Drinks converted into AI queries across three water-accounting scopes, plus US drink categories against all of 2025's AI water use — all from peer-reviewed sources."
			image="/og/drinking-ai.png"
		/>
	</head>
	<body>
		<Header />
		<main class="drinking-ai-page">
			<div class="page-atmosphere" aria-hidden="true"></div>

			<section class="poster">
				<span class="section-kicker">Water arithmetic</span>
				<h1 class="poster-title">Drinking AI</h1>
				<p class="lede">
					Growing, brewing, and packaging one beer takes about as much water as
					<strong>331,000</strong> ChatGPT queries — using AI's own most-cited water figure.
					Pick a drink, widen the accounting scope, or switch from single queries to
					agentic tasks to stress-test the number, then watch whole US drink categories
					dwarf everything AI drank in 2025 — and what it is on track to drink in 2026.
				</p>
			</section>

			<section class="workspace animate-fade-in-up delay-100" aria-labelledby="calculator-heading">
				<h2 id="calculator-heading" class="sr-only">One drink in ChatGPT queries</h2>

				<div class="console">
					<section class="result-panel" aria-live="polite">
						<div class="result-label">One <span data-result-name>{defaultDrink.name.toLowerCase()}</span> ≈</div>
						<div class="result-number" data-result-number>{defaultCell.count.toLocaleString()}</div>
						<div class="result-unit" data-result-unit>{defaultWorkload.unit}</div>
						<p class="result-usage">
							Enough water for {QUERIES_PER_DAY} <span data-result-daily>{defaultWorkload.daily}</span> a day for
							<strong data-result-usage>{defaultCell.usage}</strong>.
						</p>
						<p class="result-range">
							Across accounting scopes: <span data-result-range>{defaultDrink.rangeLow.toLocaleString()}–{defaultDrink.rangeHigh.toLocaleString()}</span> <span data-result-range-unit>{defaultWorkload.daily}</span>.
						</p>
					</section>

					<div class="console-controls">
						<div class="controls" role="group" aria-label="Drink selector">
							{clientDrinks.map((drink, index) => (
								<button
									type="button"
									class={`drink-button${index === 0 ? ' is-active' : ''}`}
									aria-pressed={index === 0 ? 'true' : 'false'}
									data-drink={drink.id}
								>
									<span class="drink-name">{drink.name}</span>
									<span class="drink-serving">{drink.serving}</span>
								</button>
							))}
						</div>

						<div class="scope-control">
							<span class="scope-label">Water counted per unit</span>
							<div class="scope-pills" role="group" aria-label="AI water-accounting scope">
								{clientScopes.map((scope) => (
									<button
										type="button"
										class={`scope-pill${scope.id === defaultScope.id ? ' is-active' : ''}`}
										aria-pressed={scope.id === defaultScope.id ? 'true' : 'false'}
										data-scope={scope.id}
									>
										<span class="scope-pill-label">{scope.label}</span>
										<span class="scope-pill-ml">{scope.perQueryMl < 1 ? scope.perQueryMl.toFixed(2) : scope.perQueryMl} mL</span>
									</button>
								))}
							</div>
						</div>

						<div class="scope-control workload-control" id="counting-by">
							<span class="scope-label">Counting by</span>
							<div class="scope-pills" role="group" aria-label="AI workload unit">
								{clientWorkloads.map((workload) => (
									<button
										type="button"
										class={`scope-pill${workload.id === defaultWorkload.id ? ' is-active' : ''}`}
										aria-pressed={workload.id === defaultWorkload.id ? 'true' : 'false'}
										data-workload={workload.id}
									>
										<span class="scope-pill-label">{workload.label}</span>
										<span class="scope-pill-ml">{workload.multiple}×</span>
									</button>
								))}
							</div>
						</div>
					</div>

					<div class="dot-field-card">
						<div class="dot-field-header">
							<span class="dot-legend"><span class="dot-swatch" aria-hidden="true"></span>1 drop = {QUERIES_PER_DROP.toLocaleString()} <span data-dot-unit>{defaultWorkload.daily}</span></span>
							<span class="dot-count"><strong data-dot-count>{defaultCell.drops.toLocaleString()}</strong> <span data-drops-word>{defaultCell.drops === 1 ? 'drop' : 'drops'}</span></span>
						</div>
						<div class="dot-field" data-dot-field aria-hidden="true"></div>
					</div>
				</div>

				<aside class="detail-rail">
					<div class="detail-item">
						<div class="detail-label">Drink water footprint</div>
						<div class="detail-value" data-result-water>{defaultDrink.waterLiters.toFixed(1)} liters</div>
						<p data-result-derivation>{defaultDrink.derivation}</p>
					</div>
					<div class="detail-item">
						<div class="detail-label">
							What's counted
							<span class="flag-tag" data-result-flag hidden>industry estimate</span>
						</div>
						<p class="detail-note" data-result-note>{defaultDrink.scopeNote}</p>
						<p class="detail-source" data-result-sources set:html={defaultDrink.sources.map((s) => `<a href="${s.url}" target="_blank" rel="noopener">${s.label}</a>`).join(' · ') || 'No external source needed'} />
					</div>
					<div class="detail-item ai-baseline">
						<div class="detail-label">AI water per <span data-unit-singular>{defaultWorkload.unitSingular}</span></div>
						<div class="detail-value">
							<span data-perunit-ml>{defaultPerUnitMl < 1 ? defaultPerUnitMl.toFixed(2) : defaultPerUnitMl}</span> mL
							<span class="scope-boundary" data-scope-boundary>{defaultScope.boundary}</span>
						</div>
						<p data-scope-detail>{defaultScope.detail}</p>
						<p class="detail-note workload-detail" data-workload-detail hidden>{defaultWorkload.detail}</p>
						<p class="detail-source" data-ai-sources set:html={`<a href="${defaultScope.sourceUrl}" target="_blank" rel="noopener">${defaultScope.sourceLabel}</a>`} />
					</div>
				</aside>
			</section>

			<section class="aggregate-section animate-fade-in-up delay-200" aria-labelledby="aggregate-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Aggregate view</span>
						<h2 id="aggregate-heading">A year of US drinks vs a year of global AI</h2>
					</div>
					<p class="workspace-note">
						A 2026 <a href={AI_BENCHMARK_SOURCE.url} target="_blank" rel="noopener">Patterns paper</a>
						models the water footprint of all AI systems worldwide at
						{formatLiters(AI_2025_MIN_LITERS)} to {formatLiters(AI_2025_MAX_LITERS)} in 2025.
						The bars share one linear scale.
					</p>
				</div>

				<div class="chart" data-chart role="img" aria-label={`Annual water footprints on one scale: global AI ${formatLiters(AI_2025_MIN_LITERS)} to ${formatLiters(AI_2025_MAX_LITERS)} in 2025, projected ${formatLiters(AI_2026_MIN_LITERS)} to ${formatLiters(AI_2026_MAX_LITERS)} in 2026 (extrapolation); ${AGGREGATE_CATEGORIES.map((c) => `US ${c.name.toLowerCase()} ${formatLiters(c.totalWaterLiters)} (${formatMultipleRange(c.multipleMin, c.multipleMax)} AI)`).join('; ')}.`}>
					<div class="chart-row is-ai">
						<div class="chart-head">
							<span class="chart-name">All global AI <span class="chart-year">2025, modeled</span></span>
							<span class="chart-value">{formatLiters(AI_2025_MIN_LITERS)} – {formatLiters(AI_2025_MAX_LITERS)}</span>
						</div>
						<div class="chart-track">
							<div
								class="chart-bar ai-bar"
								style={`--w: ${(AI_2025_MAX_LITERS / chartMaxLiters) * 100}%`}
							>
								<div class="ai-bar-min" style={`width: ${(AI_2025_MIN_LITERS / AI_2025_MAX_LITERS) * 100}%`}></div>
							</div>
						</div>
						<p class="chart-meta">Solid: low estimate. Faded: high estimate. World total, all AI systems, consumption.</p>
					</div>

					<div class="chart-row is-ai">
						<div class="chart-head">
							<span class="chart-name">All global AI <span class="chart-year">2026, projected</span> <span class="flag-tag">extrapolation</span></span>
							<span class="chart-value">{formatLiters(AI_2026_MIN_LITERS)} – {formatLiters(AI_2026_MAX_LITERS)}</span>
						</div>
						<div class="chart-track">
							<div
								class="chart-bar ai-bar is-projected"
								style={`--w: ${(AI_2026_MAX_LITERS / chartMaxLiters) * 100}%`}
							>
								<div class="ai-bar-min" style={`width: ${(AI_2026_MIN_LITERS / AI_2026_MAX_LITERS) * 100}%`}></div>
							</div>
						</div>
						<p class="chart-meta">Claude estimate: 2025 scaled by {AI_POWER_GROWTH_2025_TO_2026}× AI-power growth (published rates span 1.3–2.45×). Still a sliver of the chart.</p>
					</div>

					{AGGREGATE_CATEGORIES.map((category) => (
						<div class="chart-row">
							<div class="chart-head">
								<span class="chart-name">
									US {category.name.toLowerCase()} <span class="chart-year">{category.year}</span>
									{category.flagged && <span class="flag-tag">soft estimate</span>}
								</span>
								<span class="chart-value">
									{formatLiters(category.totalWaterLiters)}
									<span class="chart-multiple">{formatMultipleRange(category.multipleMin, category.multipleMax)} AI</span>
								</span>
							</div>
							<div class="chart-track">
								<div
									class="chart-bar"
									style={`--w: ${(category.totalWaterLiters / chartMaxLiters) * 100}%`}
								></div>
							</div>
							<p class="chart-meta">
								{category.volumeNote} · {category.footprintNote} ·{' '}
								{category.sources.map((source, i) => (
									<>
										<a href={source.url} target="_blank" rel="noopener">{source.label}</a>{i < category.sources.length - 1 ? ', ' : ''}
									</>
								))}
							</p>
						</div>
					))}
				</div>

				<p class="chart-total">
					The eight categories sum to {formatLiters(AGGREGATE_TOTAL_LITERS)} a year —
					{formatMultipleRange(AGGREGATE_TOTAL_MULTIPLE_MIN, AGGREGATE_TOTAL_MULTIPLE_MAX)} the 2025 AI range,
					or {formatMultipleRange(AGGREGATE_TOTAL_MULTIPLE_2026_MIN, AGGREGATE_TOTAL_MULTIPLE_2026_MAX)} the projected 2026 range.
					The AI estimate covers the world; the drink totals cover the US only, so world
					drink totals would sit further right.
				</p>
			</section>

			<section class="horizon animate-fade-in-up delay-300" aria-labelledby="horizon-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Where this is heading</span>
						<h2 id="horizon-heading">2026, and the shift from queries to agents</h2>
					</div>
				</div>
				<div class="horizon-grid">
					<div class="horizon-column">
						<h3>Extrapolating to 2026</h3>
						<p>
							No one publishes a 2026 AI-water figure, so this is a Claude estimate. The
							Patterns model is mechanically AI power × a fixed water intensity, and AI
							power grew 2.45× from 2024 to 2025. Published rates for 2025→2026 run from
							<a href="https://www.iea.org/reports/energy-and-ai" target="_blank" rel="noopener">~1.3× (IEA accelerated servers)</a>
							up to that 2.45× pace; scaling the 2025 range by a central {AI_POWER_GROWTH_2025_TO_2026}×
							gives roughly {formatLiters(AI_2026_MIN_LITERS)} to {formatLiters(AI_2026_MAX_LITERS)} for 2026.
							A <a href="https://unu.edu/inweh/news/environmental-cost-of-AIs-Enrgy-use-carbon-water-and-land-footprints" target="_blank" rel="noopener">UN University study</a>
							independently implies about 0.9 trillion L of AI water in 2025, near the same band.
							Even on the most aggressive growth, the drink categories still outweigh AI by tens of times.
						</p>
					</div>
					<div class="horizon-column">
						<h3>A query is becoming a task</h3>
						<p>
							The 0.32 mL figure is a <em>median single prompt</em>. Reasoning models emit
							far more tokens, and agents chain many calls per task, so the honest unit is
							shifting. Holding the on-site scope fixed, one beer is:
						</p>
						<div class="unit-strip">
							{beerUnits.map((u) => (
								<div class="unit-row">
									<span class="unit-count">{u.count.toLocaleString()}</span>
									<span class="unit-name">{u.label}{u.multiple > 1 ? ` · ${u.multiple}× a query` : ''}</span>
								</div>
							))}
						</div>
						<p class="horizon-caveat">
							Multipliers from
							<a href="https://epoch.ai/gradient-updates/how-much-energy-does-chatgpt-use" target="_blank" rel="noopener">Epoch</a>,
							<a href="https://arxiv.org/abs/2505.09598" target="_blank" rel="noopener">Jegham et al.</a>, and
							<a href="https://www.anthropic.com/engineering/multi-agent-research-system" target="_blank" rel="noopener">Anthropic</a>
							(multi-agent ≈ 15× a chat's tokens). Per-task water rises, but so does what each
							task does — a beer still covers tens of thousands of even the heaviest ones.
						</p>
					</div>
				</div>
			</section>

			<section class="methodology animate-fade-in-up delay-300" aria-labelledby="methodology-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Methodology</span>
						<h2 id="methodology-heading">What's measured, and what isn't</h2>
					</div>
				</div>
				<div class="methodology-grid">
					<div class="methodology-column">
						<h3>The per-query figure is a range</h3>
						<p>
							Published water-per-query numbers span more than 100x, almost entirely because
							of where the boundary is drawn.
							<a href="https://blog.samaltman.com/the-gentle-singularity" target="_blank" rel="noopener">OpenAI</a>
							and <a href="https://cloud.google.com/blog/products/infrastructure/measuring-the-environmental-impact-of-ai-inference/" target="_blank" rel="noopener">Google</a>
							report about 0.26–0.32 mL for data-center cooling alone. Add the water used to
							generate the electricity and an efficient 2025 model lands near 2 mL
							(<a href="https://arxiv.org/abs/2505.09598" target="_blank" rel="noopener">Jegham et al.</a>).
							A full per-response life-cycle assessment of a large model reaches 45 mL
							(<a href="https://mistral.ai/news/our-contribution-to-a-global-environmental-standard-for-ai" target="_blank" rel="noopener">Mistral</a>).
							The selector shows all three; even at 45 mL, one beer still equals more than 2,000 queries.
						</p>
					</div>
					<div class="methodology-column">
						<h3>The AI annual figure</h3>
						<p>
							<a href={AI_BENCHMARK_SOURCE.url} target="_blank" rel="noopener">de Vries-Gao (Patterns, 2026)</a>
							models AI worldwide at 312.5–764.6 billion liters consumed in 2025, built up
							from data-center disclosures rather than a directly reported total. It covers
							the whole world.
							<a href="https://eta-publications.lbl.gov/sites/default/files/2024-12/lbnl-2024-united-states-data-center-energy-usage-report_1.pdf" target="_blank" rel="noopener">LBNL</a>
							separately puts all US data centers near 17 billion gallons on-site in 2023. A
							competing projection from
							<a href="https://arxiv.org/abs/2304.03271" target="_blank" rel="noopener">Li & Ren</a>
							reaches 4.2–6.6 billion m³ by 2027, but measures withdrawal, not consumption —
							a different quantity, so it is not charted here.
						</p>
					</div>
					<div class="methodology-column">
						<h3>Drink footprints</h3>
						<p>
							Beer, wine, juice, coffee, tea, and milk use the canonical peer-reviewed crop
							and animal water tables
							(<a href="https://hess.copernicus.org/articles/15/1577/2011/hess-15-1577-2011.pdf" target="_blank" rel="noopener">Mekonnen &amp; Hoekstra 2011</a>,
							<a href="https://www.waterfootprint.org/resources/Mekonnen-Hoekstra-2012-WaterFootprintFarmAnimalProducts_1.pdf" target="_blank" rel="noopener">2012</a>) —
							full green, blue, and grey water. Coffee and tea are set by bean and leaf mass,
							not cup volume. Soda uses the low end of the 169–309 L range
							(<a href="https://ayhoekstra.nl/pubs/Ercin-et-al-2011.pdf" target="_blank" rel="noopener">Ercin et al. 2011</a>).
							Bottled water is a 1.39 L/L facility ratio and tap water is just the glass, so
							both understate next to the crop-based drinks. Spirits is the one industry figure,
							and the crop literature suggests it undercounts.
						</p>
					</div>
					<div class="methodology-column">
						<h3>US volumes</h3>
						<p>
							Each category uses its latest public total: beer and wine from
							<a href="https://www.niaaa.nih.gov/sites/default/files/surveillance-report122.Per-Capita-Consumption.pdf" target="_blank" rel="noopener">NIAAA (2023)</a>,
							orange juice from
							<a href="https://ers.usda.gov/media/5349/fruit-juices.csv?v=60123" target="_blank" rel="noopener">USDA ERS (2021, the latest in the series)</a>,
							milk from
							<a href="https://www.ers.usda.gov/data-products/dairy-data/" target="_blank" rel="noopener">USDA ERS (2024)</a>,
							coffee from
							<a href="https://apps.fas.usda.gov/psdonline/circulars/coffee.pdf" target="_blank" rel="noopener">USDA FAS (2024/25, by bean mass)</a>,
							bottled water and soda from
							<a href="https://bottledwater.org/wp-content/uploads/2026/01/2025-Progress-Report_FINAL.pdf" target="_blank" rel="noopener">IBWA (2025)</a>.
							Soda has no published total, so it comes from IBWA's own per-capita figure and
							implied population. Tea is the softest number — an industry serving count
							(<a href="https://www.teausa.org/tea-fact-sheet" target="_blank" rel="noopener">Tea Association</a>).
							<a href="https://andymasley.substack.com/p/individual-ai-use-is-not-bad-for" target="_blank" rel="noopener">Andy Masley's post</a>
							prompted the question.
						</p>
					</div>
				</div>
			</section>

			<section class="sources animate-fade-in-up delay-300" aria-labelledby="sources-heading">
				<div class="section-heading">
					<div>
						<span class="section-kicker">Sources</span>
						<h2 id="sources-heading">All linked</h2>
					</div>
				</div>
				{sourceGroups.map((group) => (
					<div class="source-group">
						<h3 class="source-group-title">{group}</h3>
						<div class="source-list">
							{sourceCards.filter((s) => s.group === group).map((source) => (
								<a href={source.url} class="source-item" target="_blank" rel="noopener">
									<h4>{source.title}</h4>
									<p>{source.detail}</p>
								</a>
							))}
						</div>
					</div>
				))}
			</section>
		</main>
		<Footer />

		<script define:vars={{ clientDrinks, clientScopes, clientWorkloads, defaultScopeId: defaultScope.id, defaultWorkloadId: defaultWorkload.id }}>
			const drinkMap = Object.fromEntries(clientDrinks.map((drink) => [drink.id, drink]));
			const scopeMap = Object.fromEntries(clientScopes.map((scope) => [scope.id, scope]));
			const workloadMap = Object.fromEntries(clientWorkloads.map((w) => [w.id, w]));
			const drinkButtons = Array.from(document.querySelectorAll('.drink-button'));
			const scopePills = Array.from(document.querySelectorAll('[data-scope]'));
			const workloadPills = Array.from(document.querySelectorAll('[data-workload]'));

			const nameEl = document.querySelector('[data-result-name]');
			const numberEl = document.querySelector('[data-result-number]');
			const unitEl = document.querySelector('[data-result-unit]');
			const dailyEl = document.querySelector('[data-result-daily]');
			const usageEl = document.querySelector('[data-result-usage]');
			const rangeEl = document.querySelector('[data-result-range]');
			const rangeUnitEl = document.querySelector('[data-result-range-unit]');
			const waterEl = document.querySelector('[data-result-water]');
			const derivationEl = document.querySelector('[data-result-derivation]');
			const noteEl = document.querySelector('[data-result-note]');
			const sourcesEl = document.querySelector('[data-result-sources]');
			const flagEl = document.querySelector('[data-result-flag]');
			const unitSingularEl = document.querySelector('[data-unit-singular]');
			const perUnitMlEl = document.querySelector('[data-perunit-ml]');
			const scopeBoundaryEl = document.querySelector('[data-scope-boundary]');
			const scopeDetailEl = document.querySelector('[data-scope-detail]');
			const workloadDetailEl = document.querySelector('[data-workload-detail]');
			const aiSourcesEl = document.querySelector('[data-ai-sources]');
			const dotFieldEl = document.querySelector('[data-dot-field]');
			const dotCountEl = document.querySelector('[data-dot-count]');
			const dotUnitEl = document.querySelector('[data-dot-unit]');
			const dropsWordEl = document.querySelector('[data-drops-word]');

			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const fmtMl = (ml) => (ml < 1 ? ml.toFixed(2) : String(Math.round(ml * 100) / 100));
			const link = (label, url) => `<a href="${url}" target="_blank" rel="noopener">${label}</a>`;

			let currentDrinkId = clientDrinks[0].id;
			let currentScopeId = defaultScopeId;
			let currentWorkloadId = defaultWorkloadId;
			const cellFor = (d, s, w) => drinkMap[d].byCombo[`${s}:${w}`];
			let currentCount = cellFor(currentDrinkId, currentScopeId, currentWorkloadId).count;
			let numberFrame = null;
			let numberTimeout = null;

			function animateNumber(from, to) {
				if (numberFrame) cancelAnimationFrame(numberFrame);
				if (numberTimeout) clearTimeout(numberTimeout);
				const setFinal = () => {
					numberEl.textContent = to.toLocaleString();
				};
				if (reduceMotion || document.hidden || from === to) {
					setFinal();
					return;
				}
				const duration = 500;
				const start = performance.now();
				function tick(now) {
					const t = Math.min(1, (now - start) / duration);
					const eased = 1 - Math.pow(1 - t, 3);
					numberEl.textContent = Math.round(from + (to - from) * eased).toLocaleString();
					if (t < 1) numberFrame = requestAnimationFrame(tick);
				}
				numberFrame = requestAnimationFrame(tick);
				// rAF pauses in hidden tabs; this guarantees the final value regardless.
				numberTimeout = setTimeout(setFinal, duration + 100);
			}

			function renderDots(drops, subDrop) {
				dotFieldEl.replaceChildren();
				const fragment = document.createDocumentFragment();
				const perDotDelay = reduceMotion ? 0 : Math.min(900 / drops, 4);
				for (let i = 0; i < drops; i++) {
					const dot = document.createElement('span');
					dot.className = subDrop ? 'dot dot--fraction' : 'dot';
					if (perDotDelay > 0) dot.style.animationDelay = `${(i * perDotDelay).toFixed(1)}ms`;
					else dot.style.animation = 'none';
					fragment.appendChild(dot);
				}
				dotFieldEl.appendChild(fragment);
				dotCountEl.textContent = subDrop ? '<1' : drops.toLocaleString();
				dropsWordEl.textContent = drops === 1 ? 'drop' : 'drops';
			}

			function render() {
				const drink = drinkMap[currentDrinkId];
				const scope = scopeMap[currentScopeId];
				const workload = workloadMap[currentWorkloadId];
				const cell = cellFor(currentDrinkId, currentScopeId, currentWorkloadId);

				nameEl.textContent = drink.name.toLowerCase();
				animateNumber(currentCount, cell.count);
				currentCount = cell.count;
				unitEl.textContent = workload.unit;
				dailyEl.textContent = workload.daily;
				usageEl.textContent = cell.usage;

				// Range across accounting scopes at the current workload — unit stays consistent.
				const scopeCounts = clientScopes.map((s) => cellFor(currentDrinkId, s.id, currentWorkloadId).count);
				rangeEl.textContent = `${Math.min(...scopeCounts).toLocaleString()}–${Math.max(...scopeCounts).toLocaleString()}`;
				rangeUnitEl.textContent = workload.daily;

				waterEl.textContent = `${drink.waterLiters.toFixed(1)} liters`;
				derivationEl.textContent = drink.derivation;
				noteEl.textContent = drink.scopeNote;
				sourcesEl.innerHTML = drink.sources.length
					? drink.sources.map((s) => link(s.label, s.url)).join(' · ')
					: 'No external source needed';
				flagEl.hidden = !drink.flagged;

				unitSingularEl.textContent = workload.unitSingular;
				perUnitMlEl.textContent = fmtMl(scope.perQueryMl * workload.multiple);
				scopeBoundaryEl.textContent = scope.boundary;
				scopeDetailEl.textContent = scope.detail;
				if (workload.multiple > 1) {
					workloadDetailEl.textContent = workload.detail;
					workloadDetailEl.hidden = false;
					aiSourcesEl.innerHTML = `${link(scope.sourceLabel, scope.sourceUrl)} · ${link(workload.sourceLabel, workload.sourceUrl)}`;
				} else {
					workloadDetailEl.hidden = true;
					aiSourcesEl.innerHTML = link(scope.sourceLabel, scope.sourceUrl);
				}

				renderDots(cell.drops, cell.subDrop);
				dotUnitEl.textContent = workload.daily;

				drinkButtons.forEach((button) => {
					const isActive = button.dataset.drink === currentDrinkId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});
				scopePills.forEach((pill) => {
					const isActive = pill.dataset.scope === currentScopeId;
					pill.classList.toggle('is-active', isActive);
					pill.setAttribute('aria-pressed', String(isActive));
				});
				workloadPills.forEach((pill) => {
					const isActive = pill.dataset.workload === currentWorkloadId;
					pill.classList.toggle('is-active', isActive);
					pill.setAttribute('aria-pressed', String(isActive));
				});
			}

			drinkButtons.forEach((button) => {
				button.addEventListener('click', () => {
					currentDrinkId = button.dataset.drink;
					render();
				});
			});
			scopePills.forEach((pill) => {
				pill.addEventListener('click', () => {
					currentScopeId = pill.dataset.scope;
					render();
				});
			});
			workloadPills.forEach((pill) => {
				pill.addEventListener('click', () => {
					currentWorkloadId = pill.dataset.workload;
					render();
				});
			});

			{
				const initialCell = cellFor(currentDrinkId, currentScopeId, currentWorkloadId);
				renderDots(initialCell.drops, initialCell.subDrop);
			}

			// Bars start collapsed only when JS runs; they grow on first scroll into view.
			const chart = document.querySelector('[data-chart]');
			if (chart && !reduceMotion && !document.hidden && 'IntersectionObserver' in window) {
				const bars = Array.from(chart.querySelectorAll('.chart-bar'));
				bars.forEach((bar) => {
					bar.style.width = '0%';
				});
				const release = () => {
					bars.forEach((bar) => {
						bar.style.width = '';
					});
					observer.disconnect();
					clearTimeout(releaseTimeout);
				};
				const observer = new IntersectionObserver(
					(entries) => {
						if (entries.some((entry) => entry.isIntersecting)) release();
					},
					{ threshold: 0.2 },
				);
				observer.observe(chart);
				// Safety: never leave the chart collapsed (hidden tabs, odd viewports).
				const releaseTimeout = setTimeout(release, 4000);
			}
		</script>
	</body>
</html>


---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing | ${SITE_TITLE}`} description="Notes on policy, code, and probability." />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1>Writing</h1>
				<p class="intro">Notes on policy, code, and probability.</p>
			</header>

			<div class="post-list">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-row">
						<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
						<span class="post-body">
							<span class="post-title">{post.data.title}</span>
							<span class="post-desc">{post.data.description}</span>
						</span>
						{post.data.heroImage && (
							<span class="post-thumb">
								<Image width={240} height={126} src={post.data.heroImage} alt="" />
							</span>
						)}
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 900px;
	}

	.page-header {
		padding: 2.5rem 0 1.5rem;
	}

	.page-header h1 {
		font-size: clamp(2.4rem, 4.5vw, 3.25rem);
		font-weight: 500;
		margin-bottom: 0.5rem;
	}

	.intro {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.15rem;
		color: var(--ink-soft);
		margin: 0;
	}

	.post-list {
		display: flex;
		flex-direction: column;
	}

	.post-row {
		display: grid;
		grid-template-columns: 108px 1fr auto;
		gap: 1.5rem;
		align-items: center;
		padding: 1.25rem 0.25rem;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		transition: background var(--duration-fast) var(--ease-out);
	}

	.post-row:first-child {
		border-top: 1px solid var(--line);
	}

	.post-row:hover {
		background: rgba(33, 29, 24, 0.02);
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--ink-muted);
		white-space: nowrap;
		align-self: start;
		padding-top: 0.35rem;
	}

	.post-body {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--ink);
		line-height: 1.3;
	}

	.post-row:hover .post-title {
		color: var(--rule-deep);
	}

	.post-desc {
		font-size: 0.9rem;
		color: var(--ink-soft);
		line-height: 1.55;
	}

	.post-thumb {
		width: 120px;
		flex-shrink: 0;
	}

	.post-thumb img {
		width: 120px;
		height: 63px;
		object-fit: cover;
		border-radius: var(--radius-md);
		border: 1px solid var(--line);
		display: block;
	}

	@media (max-width: 640px) {
		.post-row {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.post-date {
			padding-top: 0;
		}

		.post-thumb {
			display: none;
		}
	}
</style>

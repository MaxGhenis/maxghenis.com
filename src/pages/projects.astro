---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const organizations = [
	{
		title: 'The Axiom Foundation',
		href: 'https://axiom-foundation.org',
		role: 'Founder & CEO · 2026—',
		description:
			'Publishes the law as open, verified code — every value citing its statute, every clause carrying its effective date, every encoding checked against independent implementations. Starts with tax and benefit policy; launches publicly July 28, 2026, with PolicyEngine as its first and most demanding consumer.',
	},
	{
		title: 'PolicyEngine',
		href: 'https://policyengine.org',
		role: 'Co-founder & CEO · 2021—',
		description:
			'Free, open-source software that computes taxes and benefits for any household and simulates reforms across whole populations. Policymakers, researchers, and benefit navigators use it in the US, UK, and Canada. See the research portfolio at policyengine.org/us/research.',
	},
	{
		title: 'UBI Center',
		href: 'https://ubicenter.org',
		role: 'Founder · 2019–2023',
		description:
			'Open-source think tank researching universal basic income and cash transfer policies. The team produced over 60 reports on UBI proposals, child allowances, and carbon dividends.',
	},
];

const products = [
	{
		title: 'PolicyBench',
		href: 'https://policybench.org',
		repo: 'https://github.com/PolicyEngine/policybench',
		description: 'Open benchmark scoring AI models on tax and benefit law, graded against exact calculations.',
		tag: 'AI eval',
		pole: 'cast',
	},
	{
		title: 'populace',
		href: 'https://populace.dev',
		description: 'Calibrated survey microdata for policy simulation — national to local, fully reproducible.',
		tag: 'Microdata',
		pole: 'cast',
	},
	{
		title: 'HiveSight',
		href: 'https://hivesight.ai',
		description: 'Estimates public opinion by segment, grounding language models in survey microdata.',
		tag: 'Opinion',
		pole: 'cast',
	},
	{
		title: 'EggNest',
		href: 'https://eggnest.co',
		description: 'Monte Carlo financial planning with real tax calculations.',
		tag: 'Finance',
		pole: 'cast',
	},
	{
		title: 'OptiQAL',
		href: 'https://optiqal.ai',
		description: 'AI-assisted QALY estimation for lifestyle choices.',
		tag: 'Health',
		pole: 'cast',
	},
	{
		title: 'CodeStitch',
		href: 'https://codestitch.dev',
		repo: 'https://github.com/MaxGhenis/codestitch',
		description: 'Combines GitHub repos, PRs, and issues into single files for AI context.',
		tag: 'Dev tools',
		pole: 'rule',
	},
];

const tools = [
	{
		title: 'microdf',
		href: 'https://github.com/PolicyEngine/microdf',
		description: "Pandas extensions for weighted survey microdata, used across PolicyEngine's models.",
		tag: 'Python',
		pole: 'rule',
	},
	{
		title: 'OpenMessage',
		href: '/blog/openmessage',
		repo: 'https://github.com/MaxGhenis/openmessage',
		description: 'macOS Google Messages client that gives coding agents access to your texts.',
		tag: 'macOS',
		pole: 'rule',
	},
	{
		title: 'TerminalGrid',
		href: '/terminalgrid',
		repo: 'https://github.com/MaxGhenis/terminalgrid',
		description: 'VS Code extension for keyboard-driven terminal grids, built for agentic coding.',
		tag: 'VS Code',
		pole: 'rule',
	},
	{
		title: 'RAMBar',
		href: '/rambar',
		repo: 'https://github.com/MaxGhenis/rambar',
		description: 'Native macOS menu bar app tracking memory across Claude Code, VS Code, Chrome, and Python.',
		tag: 'macOS',
		pole: 'rule',
	},
	{
		title: 'Scrollywood',
		href: '/scrollywood',
		repo: 'https://github.com/MaxGhenis/scrollywood',
		description: 'Chrome extension recording smooth-scroll videos and GIFs of any webpage.',
		tag: 'Chrome',
		pole: 'rule',
	},
	{
		title: 'opencollective-py',
		href: '/opencollective-py',
		repo: 'https://github.com/MaxGhenis/opencollective-py',
		description: 'Python client for the OpenCollective API, with CLI and MCP server.',
		tag: 'Python',
		pole: 'rule',
	},
];

const interactives = [
	{
		title: "MacKenzie Scott's giving, in QALYs",
		href: '/mackenzie-scott-qaly',
		repo: 'https://github.com/MaxGhenis/mackenzie-scott-qaly',
		description: "GiveWell-style Monte Carlo model estimating the health impact of $26.3B in giving, running entirely in your browser.",
		tag: 'Monte Carlo',
		pole: 'cast',
	},
	{
		title: 'A year of ChatGPT is a fifth of a beer',
		href: '/drinking-ai',
		description: 'Prices drinks in AI queries, and lets you flip every assumption behind published AI water numbers.',
		tag: 'Explorable',
		pole: 'cast',
	},
	{
		title: 'Voter guides',
		href: '/voter-guides/',
		description: 'Recommendations for California elections — propositions, candidates, and local measures.',
		tag: 'Civic',
		pole: 'rule',
	},
];

const papers = [
	{
		title: 'What can LLMs tell us about the ETI?',
		authors: 'Max Ghenis & Jason DeBacker',
		status: 'Working paper',
		date: '2025',
		abstract:
			'We investigate how large language models perceive and simulate behavioral responses to tax policy changes, with implications for using LLMs in policy analysis.',
		links: [
			{ label: 'Read', href: '/llm-eti/' },
			{ label: 'PDF', href: '/llm-eti/book.pdf' },
			{ label: 'SSRN', href: 'https://papers.ssrn.com/sol3/papers.cfm?abstract_id=5410643' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/llm-eti' },
		],
	},
	{
		title: 'Enhancing survey microdata with administrative records',
		authors: 'Max Ghenis & Nikhil Woodruff',
		status: 'Published',
		venue: 'National Tax Association Annual Meeting',
		date: 'November 2024',
		abstract:
			'A novel approach to microsimulation dataset construction that combines Current Population Survey data with IRS administrative records for improved tax-benefit modeling.',
		links: [
			{ label: 'PDF', href: 'https://github.com/PolicyEngine/policyengine-us-data/blob/main/paper/main.pdf' },
			{ label: 'Code', href: 'https://github.com/PolicyEngine/policyengine-us-data' },
		],
	},
	{
		title: 'Can LLMs forecast human value evolution?',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2025',
		abstract:
			'Testing whether language models can predict moral and value change trajectories using historical General Social Survey data as ground truth.',
		links: [
			{ label: 'Read', href: '/value-forecasting/' },
			{ label: 'PDF', href: '/value-forecasting/value-forecasting.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/value-forecasting' },
		],
	},
	{
		title: 'AI model policy impact forecasts: A narrative prompting approach',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2024',
		abstract:
			'Examining the use of large language models for forecasting policy outcomes under different U.S. presidential administrations using narrative prompting techniques.',
		links: [
			{ label: 'PDF', href: 'https://github.com/MaxGhenis/llm-presidential-outcome-forecasts/blob/main/paper/main.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/llm-presidential-outcome-forecasts' },
		],
	},
	{
		title: 'The double distortion: Income-based traffic fines and labor supply',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2025',
		abstract:
			'Agent-based simulation analyzing welfare effects of income-based vs flat traffic fines, showing labor supply distortions from implicit marginal tax rates.',
		links: [
			{ label: 'Read', href: '/traffic-fine-sim/' },
			{ label: 'PDF', href: '/traffic-fine-sim/traffic-fines.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/traffic-fine-sim' },
		],
	},
	{
		title: 'The disutility of uncertainty',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2025',
		abstract: 'How uncertainty around marginal tax rates affects social welfare.',
		links: [
			{ label: 'Read', href: '/disutility-of-uncertainty/' },
			{ label: 'PDF', href: '/disutility-of-uncertainty/tax-uncertainty.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/disutility-of-uncertainty' },
		],
	},
	{
		title: 'What Nut?',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2025',
		abstract:
			'Monte Carlo analysis of life expectancy from nut consumption, with evidence-traced claims and hierarchical nutrient models.',
		links: [
			{ label: 'Read', href: '/whatnut-paper/' },
			{ label: 'PDF', href: '/whatnut-paper/whatnut.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/whatnut' },
		],
	},
	{
		title: 'Beer price controls at Yankee Stadium',
		authors: 'Max Ghenis',
		status: 'Working paper',
		date: '2024',
		abstract:
			'An economic analysis of consumer welfare, revenue, and externalities from stadium beer pricing policies.',
		links: [
			{ label: 'Read', href: '/yankee-stadium-beer-price-controls/' },
			{ label: 'PDF', href: '/yankee-stadium-beer-price-controls/beer-price-controls.pdf' },
			{ label: 'Code', href: 'https://github.com/MaxGhenis/yankee-stadium-beer-price-controls' },
		],
	},
	{
		title: 'The Mind: LLM coordination',
		authors: 'Max Ghenis',
		status: 'In progress',
		date: '2025',
		abstract:
			'Simulating The Mind card game with large language models to study emergent coordination without explicit communication.',
		links: [{ label: 'Code', href: 'https://github.com/MaxGhenis/the-mind' }],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description="Software projects and academic research by Max Ghenis" />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1>Projects</h1>
				<p class="intro">
					Software I've built and research I've published — mostly at the
					intersection of policy, economics, and AI. Rules on one side,
					forecasts on the other, and a third thread estimating what people
					value; most of it lives in between.
				</p>
			</header>

			<section class="block">
				<span class="eyebrow">Organizations</span>
				<div class="org-list">
					{organizations.map((org) => (
						<a href={org.href} class="org-card" target="_blank" rel="noopener">
							<div class="org-seam" aria-hidden="true"></div>
							<div class="org-body">
								<span class="org-role">{org.role}</span>
								<h2>{org.title}</h2>
								<p>{org.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="block">
				<span class="eyebrow">Products &amp; platforms</span>
				<div class="card-grid">
					{products.map((item) => (
						<a href={item.href} class="card" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined}>
							<span class={`card-tag ${item.pole}-tag`}>{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="block">
				<span class="eyebrow">Tools &amp; libraries</span>
				<div class="card-grid">
					{tools.map((item) => (
						<a href={item.href} class="card" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener' : undefined}>
							<span class={`card-tag ${item.pole}-tag`}>{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="block">
				<span class="eyebrow">Interactives &amp; analyses</span>
				<div class="card-grid">
					{interactives.map((item) => (
						<a href={item.href} class="card">
							<span class={`card-tag ${item.pole}-tag`}>{item.tag}</span>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="block" id="research">
				<span class="eyebrow">Research &amp; working papers</span>
				<div class="papers">
					{papers.map((paper) => (
						<article class="paper">
							<div class="paper-head">
								<h3>{paper.title}</h3>
								<span class="paper-date">{paper.date}</span>
							</div>
							<p class="paper-meta">
								{paper.authors}
								{paper.venue && <span> · {paper.venue}</span>}
								<span> · {paper.status}</span>
							</p>
							<p class="paper-abstract">{paper.abstract}</p>
							<div class="paper-links">
								{paper.links.map((link) => (
									<a href={link.href} {...(link.href.startsWith('/') ? {} : { target: '_blank', rel: 'noopener' })}>{link.label}</a>
								))}
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="block lab-note">
				<p>
					Smaller experiments — games, prototypes, one-offs — live in
					<a href="/lab">the lab</a>.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: 2.5rem 0 1rem;
	}

	.page-header h1 {
		font-size: clamp(2.4rem, 4.5vw, 3.25rem);
		font-weight: 500;
		margin-bottom: 0.75rem;
	}

	.intro {
		color: var(--ink-soft);
		font-size: 1.1rem;
		max-width: 640px;
		margin-bottom: 1rem;
	}

	.block {
		margin-bottom: 4rem;
	}

	.block > .eyebrow {
		margin-bottom: 1.5rem;
	}

	/* Organizations */
	.org-list {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.org-card {
		position: relative;
		display: block;
		padding: 1.875rem 2rem 1.875rem 2.25rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: all var(--duration-normal) var(--ease-out);
	}

	.org-card:hover {
		box-shadow: var(--shadow-lg);
		transform: translateY(-2px);
	}

	.org-seam {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: var(--seam-vertical);
	}

	.org-role {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink-muted);
		display: block;
		margin-bottom: 0.5rem;
	}

	.org-card h2 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
		color: var(--ink);
	}

	.org-card p {
		color: var(--ink-soft);
		font-size: 0.9688rem;
		max-width: 720px;
		margin: 0;
	}

	/* Card grids */
	.card-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		padding: 1.375rem 1.5rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.card:hover {
		border-color: #d9d2c2;
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.card-tag {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		margin-bottom: 0.75rem;
	}

	.rule-tag { color: var(--rule-deep); }
	.cast-tag { color: var(--cast-deep); }

	.card h3 {
		font-size: 1.15rem;
		font-weight: 600;
		margin-bottom: 0.375rem;
		color: var(--ink);
		line-height: 1.3;
	}

	.card p {
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
	}

	/* Papers */
	.papers {
		display: flex;
		flex-direction: column;
	}

	.paper {
		padding: 1.5rem 0.25rem;
		border-bottom: 1px solid var(--line);
	}

	.paper:first-of-type {
		border-top: 1px solid var(--line);
	}

	.paper-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 0.25rem;
	}

	.paper-head h3 {
		margin: 0;
		font-size: 1.2rem;
		color: var(--ink);
	}

	.paper-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--cast-deep);
		white-space: nowrap;
	}

	.paper-meta {
		font-size: 0.85rem;
		color: var(--ink-muted);
		margin-bottom: 0.625rem;
	}

	.paper-abstract {
		font-size: 0.9375rem;
		color: var(--ink-soft);
		max-width: 760px;
		margin-bottom: 0.75rem;
	}

	.paper-links {
		display: flex;
		gap: 1.25rem;
	}

	.paper-links a {
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		color: var(--rule-deep);
	}

	.paper-links a:hover {
		color: var(--rule);
	}

	/* Lab note */
	.lab-note {
		margin-bottom: 1rem;
	}

	.lab-note p {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.05rem;
		color: var(--ink-soft);
	}

	.lab-note a {
		color: var(--rule-deep);
		text-decoration: underline;
		text-decoration-thickness: 1.5px;
		text-underline-offset: 3px;
	}

	/* Responsive */
	@media (max-width: 900px) {
		.card-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.card-grid {
			grid-template-columns: 1fr;
		}

		.paper-head {
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>

---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import ogImage from '../../assets/og-mackenzie-qaly.png';
import paperHtml from '../../data/mackenzie-qaly-paper.html?raw';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`MacKenzie Scott's giving, in QALYs | ${SITE_TITLE}`}
      description="An interactive, GiveWell-style cost-effectiveness model estimating the health impact — in quality-adjusted life-years — of MacKenzie Scott's $26.3B in lifetime philanthropy. Runs entirely in your browser."
      image={ogImage}
    />
  </head>
  <body>
    <Header />
    <main>
      <header class="page-header">
        <h1>MacKenzie Scott's giving, in QALYs</h1>
        <p class="page-description">
          How much health does $26.3 billion of philanthropy buy? Drag the
          assumptions and watch a Monte Carlo cost-effectiveness model rerun in
          your browser.
        </p>
      </header>

      <nav class="surface-tabs" aria-label="Views of this analysis">
        <a class="tab" href="/mackenzie-scott-qaly">Interactive</a>
        <span class="tab active">Working paper</span>
        <a class="tab" href="/mackenzie-scott-qaly/paper/index.pdf">PDF</a>
      </nav>

      <article class="prose paper-body" set:html={paperHtml} />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1040px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .page-header {
    margin-bottom: 1.5rem;
  }
  .page-description {
    color: var(--text-muted);
    font-size: var(--text-lg);
    max-width: 640px;
  }

  .surface-tabs {
    display: flex;
    gap: 1.25rem;
    margin: 0 0 1.1rem;
    border-bottom: 1px solid var(--border, #e2e8f0);
  }
  .surface-tabs .tab {
    padding: 0 0 0.45rem;
    font-size: 0.9rem;
    color: var(--ink-muted, #64748b);
    text-decoration: none;
  }
  .surface-tabs .tab.active {
    color: #b45309;
    font-weight: 600;
    border-bottom: 2px solid #b45309;
  }
  .surface-tabs a.tab:hover {
    color: #b45309;
  }

  .paper-body {
    max-width: 760px;
    margin-left: 0;
  }
  .paper-body :global(h1) {
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    font-size: var(--text-3xl);
  }
  .paper-body :global(img) {
    max-width: 100%;
    height: auto;
  }
  .paper-body :global(figure) {
    margin: 2rem 0;
  }
  .paper-body :global(figcaption) {
    margin-bottom: 0.75rem;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .paper-body :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }
  .paper-body :global(th),
  .paper-body :global(td) {
    border: 1px solid #e2e8f0;
  }
  .paper-body :global(.abstract) {
    margin: 1.5rem 0 2rem;
    padding: 1rem 1.25rem;
    background: #f8fafc;
    border-left: 3px solid #cbd5e1;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .paper-body :global(.abstract .block-title) {
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-weight: 600;
  }
  .paper-body :global(.abstract p) {
    margin-bottom: 0;
  }
  .paper-body :global(.quarto-title-meta-container) {
    margin: 0.75rem 0;
    font-size: var(--text-sm);
  }
  .paper-body :global(.quarto-title-meta) {
    display: flex;
    gap: 0.5rem;
  }
  .paper-body :global(.quarto-title-meta-heading) {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .paper-body :global(.quarto-title-meta-contents p) {
    margin: 0;
  }
  .paper-body :global(#refs .csl-entry) {
    margin-bottom: 0.75rem;
    padding-left: 1.5em;
    text-indent: -1.5em;
  }
  .paper-body :global(#TOC),
  .paper-body :global(.toc),
  .paper-body :global(.quarto-alternate-formats),
  .paper-body :global(.quarto-alternate-notebooks),
  .paper-body :global(.quarto-notebook-link),
  .paper-body :global(.anchorjs-link),
  .paper-body :global(.anchor-link),
  .paper-body :global(button.code-copy-button) {
    display: none;
  }
</style>

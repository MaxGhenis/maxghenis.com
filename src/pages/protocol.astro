										<th>Item</th>
										<th>Dose</th>
										<th class="num">$/yr</th>
									</tr>
								</thead>
								<tbody>
									{bedtimeSchedule.map(item => (
										<tr>
											<td>{item.source_url ? <a href={item.source_url}>{item.name}</a> : item.name}</td>
											<td class="schedule-dose">{item.dose_notes}</td>
											<td class="num">{item.annual_cost > 0 ? `$${item.annual_cost}` : <em>bundled</em>}</td>

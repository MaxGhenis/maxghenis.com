---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import protocolData from '../data/protocol-data.json';
import protocolGroundUp from '../data/protocol-ground-up.json';
import ogImage from '../assets/og-protocol.png';

const { summary, supplements, bundles, portfolio, config, profile, schedule } = protocolData;
type GroundUpAction = {
	cost_per_qaly?: number | null;
	delta_cost: number;
	delta_qaly: number;
};
type OptimizerResult = {
	add_names?: string[];
	drop_names?: string[];
	delta_qaly: number;
	delta_days: number;
	p_positive_delta: number;
	delta_cost: number;
};
type ScheduleItem = {
	name: string;
	source_url?: string | null;
	dose_notes: string;
	annual_cost: number;
};
const groundUpSummary = protocolGroundUp.summary;
const referenceCaseModel = protocolGroundUp.reference_case.current_protocol_model;
const groundUpTopActions = protocolGroundUp.state_marginal_decisions.slice(0, 6);
const groundUpCurrentState = protocolGroundUp.current_state;
const groundUpOptimizers = protocolGroundUp.protocol_optimizers;
const optimizerRows = [
	{ label: '$200K/QALY net benefit', result: groundUpOptimizers?.net_benefit },
	{ label: 'QALY only', result: groundUpOptimizers?.qaly },
].filter(row => row.result) as { label: string; result: OptimizerResult }[];
const pct = (value: number) => `${(value * 100).toFixed(value * 100 % 1 === 0 ? 0 : 1)}%`;
const formatGroundUpActionCost = (item: GroundUpAction) => {
	if (item.cost_per_qaly) return `$${item.cost_per_qaly.toLocaleString()}`;
	if (item.delta_cost <= 0 && item.delta_qaly > 0) return 'dominant';
	return '—';
};
const summarizeOptimizerActions = (result: OptimizerResult) => {
	const adds = result.add_names?.length ? `Add ${result.add_names.join(', ')}` : '';
	const drops = result.drop_names?.length ? `Drop ${result.drop_names.join(', ')}` : '';
	return [adds, drops].filter(Boolean).join('; ') || 'No changes';
};
const utilityLineageSummary = groundUpSummary.items_needing_utility_lineage === 0
	? `All ${groundUpSummary.n_items} items now have explicit utility lineage or no direct-QOL overlay; ${groundUpSummary.items_using_fallback_utility_lineage} items still use disability-weight fallback lineage.`
	: `${groundUpSummary.items_needing_utility_lineage} items still need explicit EQ-5D/SF-6D/HUI or mapped utility lineage, while ${groundUpSummary.items_using_fallback_utility_lineage} items currently use disability-weight fallback lineage.`;
const bedtimeSchedule = (schedule.bedtime || []) as ScheduleItem[];
const anytimeSchedule = (schedule.anytime || []) as ScheduleItem[];

// Group supplements by category
const categories = [
	{ key: 'rx_current', label: 'Prescriptions', status: 'taking' },
	{ key: 'supplement_current', label: 'Current supplements', status: 'taking' },
	{ key: 'supplement_bought', label: 'Recently added', status: 'testing' },
	{ key: 'rx_candidate', label: 'Prescription candidates', status: 'considering' },
	{ key: 'supplement_candidate', label: 'Supplement candidates', status: 'watching' },
];

const grouped = Object.fromEntries(
	categories.map(c => [c.key, supplements.filter(s => s.category === c.key)])
);

// Top items by gross value (in portfolio)
const coreStack = supplements
	.filter(s => s.in_portfolio && (s.category === 'rx_current' || s.category === 'supplement_current' || s.category === 'supplement_bought'))
	.slice(0, 15);

// Excluded items (not in portfolio, not candidates)
const excluded = supplements
	.filter(s => !s.in_portfolio && s.category !== 'rx_candidate' && s.category !== 'supplement_candidate')
	.sort((a, b) => b.gross_value - a.gross_value);

const statusColors: Record<string, string> = {
	taking: '#059669',
	testing: '#d97706',
	considering: '#6366f1',
	watching: '#64748b',
};

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Protocol | ${SITE_TITLE}`} description="My quantified health stack: supplements, sleep optimization, and environmental interventions. Evidence-graded with Bayesian QALY analysis." image={ogImage} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1>Protocol</h1>
				<p class="page-description">My quantified health stack &mdash; supplements, sleep, and environmental optimization.</p>
				<p class="last-updated">Last updated {protocolData.generated_at}</p>
			</header>

			<div class="callout">
				This is my personal protocol, not medical advice. Most supplement evidence is observational and heavily confounded. I use a Bayesian QALY framework (<a href="https://github.com/maxghenis/optiqal-ai">Optiqal</a>) to account for confounding and publication bias. Consult your doctor before making health decisions.
			</div>

			<!-- At a glance -->
			<section>
				<h2>At a glance</h2>
				<div class="stats-grid">
					<div class="stat-card">
						<div class="stat-value">{summary.total_items}</div>
						<div class="stat-label">Daily items</div>
					</div>
					<div class="stat-card">
						<div class="stat-value">${summary.total_annual_cost.toLocaleString()}</div>
						<div class="stat-label">Annual cost</div>
					</div>
					<div class="stat-card">
						<div class="stat-value">+{Math.round(summary.total_days / 365.25 * 10) / 10}yr</div>
						<div class="stat-label">Expected QALY gain</div>
					</div>
					<div class="stat-card">
						<div class="stat-value">+{Math.round(groundUpSummary.total_stack_days)}d</div>
						<div class="stat-label">Ground-up audit</div>
					</div>
				</div>
			</section>

			<!-- Philosophy -->
			<section>
				<h2>Philosophy</h2>
				<p>I treat health optimization as a portfolio problem under uncertainty. Each intervention has an expected benefit (measured in <a href="https://en.wikipedia.org/wiki/Quality-adjusted_life_year">QALYs</a>), a cost, and uncertainty about whether the observed effect is causal or confounded.</p>
				<p>The framework: estimate each intervention's hazard ratio from literature, shrink it toward null by a <strong>tiered publication-bias correction</strong> (10% for preregistered RCTs with hard endpoints, 20&ndash;30% for standard RCTs and cohorts, 50% for supplement-industry RCTs, 70% for animal-only evidence), apply a Bayesian causal-fraction prior calibrated against observed RCT-vs-observational discrepancies, simulate 50,000 Monte Carlo samples through CDC life tables, and report the <strong>posterior hazard ratio</strong> the simulator actually applies &mdash; not the publication-bias-only HR.</p>
				<p>Mechanism-cluster diminishing returns prevent correlated supplements from stacking additively. Anti-inflammatory polyphenols (curcumin, quercetin, apigenin, EGCG, luteolin, cocoa flavanols) share a cluster with within-cluster retention dropping fast past the first item; NAD+ precursors (NR, NMN) are tightened further; antioxidants, mitochondrial-support, and senolytics each have their own steep retention schedules. A portfolio-level QALY ceiling of {summary.portfolio_qaly_ceiling ?? 3.0} applies a concave saturation to the raw additive total so the stack can't claim multi-QALY gains that exceed primary-prevention CEA literature.</p>
				<p>Key parameters: willingness-to-pay of $200K per QALY (with a sensitivity panel at $50K/$100K/$150K below), 40-year horizon, {pct(config.cost_discount_rate)} cost discount, {pct(config.qaly_discount_rate)} QALY discount. Bundled products (Blueprint Essentials, Advanced Antioxidants, Longevity Mix) now carry an allocated per-ingredient cost so bundled items no longer free-ride on $/QALY.</p>
				<p>I am not a doctor. I have no medical training. This is <em>expected value reasoning applied to personal health decisions</em>, not clinical guidance. Most of these effect sizes are small, uncertain, and could be entirely confounded.</p>
			</section>

			<section>
				<h2>Reference-case ground-up audit</h2>
				<p>This newer audit uses the US Second Panel-style 3% health and cost discounting path and item-by-item assumptions from the live protocol inventory. It is <strong>not yet a formal reference-case CUA</strong>: {utilityLineageSummary}</p>
				<p><strong>Ground-up full-state total:</strong> {groundUpSummary.total_stack_qaly.toFixed(4)} QALY ({groundUpSummary.total_stack_days.toFixed(1)} days). Additive standalone value {groundUpCurrentState.additive_qaly.toFixed(4)} QALY, shared stack adjustment {groundUpCurrentState.stack_interaction_qaly.toFixed(4)} QALY. Alignment: {referenceCaseModel.reference_case_alignment.replace(/_/g, ' ')}.</p>
				{optimizerRows.length > 0 && (
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>Constrained optimizer</th>
										<th class="num">ΔQALY</th>
										<th class="num">Days</th>
										<th class="num">P(+)</th>
										<th class="num">Δcost</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									{optimizerRows.map(({ label, result }) => (
										<tr>
											<td>{label}</td>
											<td class="num">{result.delta_qaly.toFixed(4)}</td>
											<td class="num">{result.delta_days.toFixed(1)}</td>
											<td class="num">{pct(result.p_positive_delta)}</td>
											<td class="num">${Math.round(result.delta_cost).toLocaleString()}</td>
											<td>{summarizeOptimizerActions(result)}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					)}
					<div class="table-wrapper">
						<table>
							<thead>
								<tr>
									<th>Action</th>
									<th>Item</th>
									<th>Type</th>
									<th class="num">ΔQALY</th>
									<th class="num">Days</th>
									<th class="num">P(+)</th>
									<th class="num">$/QALY</th>
								</tr>
							</thead>
							<tbody>
								{groundUpTopActions.map(item => (
									<tr>
										<td>{item.action}</td>
										<td>{item.name}</td>
										<td>{item.display_category}</td>
										<td class="num">{item.delta_qaly.toFixed(4)}</td>
										<td class="num">{item.delta_days.toFixed(1)}</td>
										<td class="num">{pct(item.p_positive)}</td>
										<td class="num">{formatGroundUpActionCost(item)}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>

			<!-- WTP sensitivity frontier -->
			{protocolData.wtp_frontier && protocolData.wtp_frontier.length > 0 && (
				<section>
					<h2>Willingness-to-pay sensitivity</h2>
					<p>The same item simulations rerun at four cost-effectiveness thresholds. At $50K/QALY &mdash; the bar common in public healthcare systems &mdash; only the highest-conviction items survive. My personal WTP is $200K, higher than standard clinical CEA because the marginal dollar on health beats the marginal dollar on most other spending for me; but the frontier is what to look at for the robust core.</p>
					<div class="table-wrapper">
						<table>
							<thead>
								<tr>
									<th class="num">WTP ($/QALY)</th>
									<th class="num">Items</th>
									<th class="num">QALY (saturated)</th>
									<th class="num">QALY (raw)</th>
									<th class="num">Days</th>
									<th class="num">$/yr</th>
								</tr>
							</thead>
							<tbody>
								{protocolData.wtp_frontier.map(row => (
									<tr>
										<td class="num">${row.wtp.toLocaleString()}</td>
										<td class="num">{row.n_items}</td>
										<td class="num">{row.total_qaly.toFixed(2)}</td>
										<td class="num">{row.total_raw_qaly.toFixed(2)}</td>
										<td class="num">+{row.total_days.toFixed(0)}</td>
										<td class="num">${row.total_annual_cost.toLocaleString()}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>
			)}

			<!-- Core stack -->
			<section>
				<h2>Core stack</h2>
				<p>The top {coreStack.length} highest-conviction items I take daily, ranked by expected value. The <strong>posterior HR</strong> column is what the simulator actually applies after publication-bias and Bayesian confounding shrinkage &mdash; much weaker than the raw literature HR and the right column for comparing items.</p>
				<div class="table-wrapper">
					<table>
						<thead>
							<tr>
								<th>Item</th>
								<th>Status</th>
								<th>Evidence</th>
								<th class="num">Posterior HR</th>
								<th class="num">E[days]</th>
								<th class="num">P(+)</th>
								<th class="num">$/yr</th>
								<th class="num">$/QALY</th>
							</tr>
						</thead>
						<tbody>
							{coreStack.map(s => (
								<tr>
										<td>
											<strong>{s.name}</strong>
											<details class="evidence-details">
												<summary>Details</summary>
												<p>
												HR observed: {s.hr_observed}<br/>
												Pub-bias corrected ({Math.round((s.pub_bias_shrinkage ?? 0.3) * 100)}% shrinkage{s.study_quality ? `, tier: ${s.study_quality.replace(/_/g, ' ')}` : ''}): {s.hr_corrected}<br/>
												{s.hr_posterior_median !== null && s.hr_posterior_median !== undefined && (
													<>Posterior (sim-applied) HR: <strong>{s.hr_posterior_median.toFixed(3)}</strong> (95% CI {s.hr_posterior_ci95_low?.toFixed(3)}&ndash;{s.hr_posterior_ci95_high?.toFixed(3)})<br/></>
												)}
												{s.bundle_id && s.bundle_cost_share > 0 && (
													<>Bundle allocation: ${s.bundle_cost_share}/yr from {s.bundle_id.replace(/_/g, ' ')}<br/></>
												)}
												{s.notes}
												{s.sources?.length > 0 && <><br/><a href={s.sources[0]}>Product link</a></>}
											</p>
										</details>
									</td>
									<td><span class="status-pill" style={`background: ${statusColors[s.status]}20; color: ${statusColors[s.status]}`}>{s.status}</span></td>
									<td><span class={`evidence-badge evidence-${s.evidence}`}>{s.evidence}</span></td>
									<td class="num">{s.hr_posterior_median != null ? s.hr_posterior_median.toFixed(3) : '\u2014'}</td>
									<td class="num">+{s.days.toFixed(0)}</td>
									<td class="num">{Math.round(s.p_benefit * 100)}%</td>
									<td class="num">{(s.effective_annual_cost ?? s.annual_cost) === 0 ? 'bundled' : `$${Math.round(s.effective_annual_cost ?? s.annual_cost)}`}</td>
									<td class="num">{s.cost_per_qaly ? `$${s.cost_per_qaly.toLocaleString()}` : '\u2014'}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<!-- Daily schedule -->
			<section>
				<h2>Daily schedule</h2>
				<p>How the stack breaks down by time of day. Generated from a private health database I maintain on GitHub. Bundles contain multiple catalog items.</p>

				<!-- Morning mix -->
				<div class="time-block">
					<h3>Morning mix</h3>
					<p>All powders mixed into water. I pre-mix several days' worth into a smaller mason jar and scoop daily.</p>
					<div class="table-wrapper">
						<table class="schedule-table">
							<thead>
								<tr>
									<th>Item</th>
									<th>Dose</th>
									<th class="num">$/yr</th>
								</tr>
							</thead>
							<tbody>
								{(schedule.morning_mix || []).map(item => (
									<tr>
										<td>{item.source_url ? <a href={item.source_url}>{item.name}</a> : item.name}</td>
										<td class="schedule-dose">{item.dose_notes}</td>
										<td class="num">{item.annual_cost > 0 ? `$${item.annual_cost}` : <em>bundled</em>}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>

				<!-- Nutty pudding + pill batch 1 -->
				<div class="time-block">
					<h3>Nutty pudding + pill batch 1</h3>
					<p>Optimized from <a href="https://www.reddit.com/r/blueprint_/comments/1jlu0dv/whats_the_latest_nutty_pudding_recipe/">Bryan Johnson's recipe</a> for QALY/$ and adherence. The current version keeps pomegranate juice for taste, uses ground macadamias and walnuts in the powder jar, blends hazelnuts and blanched almonds whole, and keeps Blueprint fruit mix out by default. I blend 4 servings at a time and refrigerate.</p>
					<div class="table-wrapper">
						<table class="schedule-table">
							<thead>
								<tr>
									<th>Item</th>
									<th>Dose</th>
									<th class="num">$/yr</th>
								</tr>
							</thead>
							<tbody>
								{(schedule.meal_1 || []).map(item => (
									<tr>
										<td>{item.source_url ? <a href={item.source_url}>{item.name}</a> : item.name}</td>
										<td class="schedule-dose">{item.dose_notes}</td>
										<td class="num">{item.annual_cost > 0 ? `$${item.annual_cost}` : <em>bundled</em>}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<details>
						<summary class="category-summary">Recipe: 1 serving and 4-serving batch</summary>
						<p>For each 4-serving batch, blend the liquid/fruit/nuts with 4 servings from the powder jar, then portion into containers and add toppings per serving.</p>
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>Ingredient</th>
										<th class="num">1 serving</th>
										<th class="num">4 servings</th>
										<th>Where</th>
									</tr>
								</thead>
								<tbody>
									<tr><td>Pomegranate juice</td><td class="num">60 ml</td><td class="num">1 cup</td><td>Blender</td></tr>
									<tr><td>Unsweetened nut milk</td><td class="num">50&ndash;100 ml</td><td class="num">200&ndash;400 ml</td><td>Blender; add water to texture</td></tr>
									<tr><td>Frozen berries + cherries</td><td class="num">&frac12; cup</td><td class="num">2 cups</td><td>Blender</td></tr>
									<tr><td>Whole hazelnuts</td><td class="num">&frac12; tbsp</td><td class="num">2 tbsp</td><td>Blender</td></tr>
									<tr><td>Whole blanched almonds</td><td class="num">&frac12; tbsp</td><td class="num">2 tbsp</td><td>Blender</td></tr>
									<tr><td>Powder jar mix</td><td class="num">1 serving</td><td class="num">4 servings</td><td>Blend after liquids/fruit/nuts</td></tr>
									<tr><td>EVOO</td><td class="num">1 tbsp</td><td class="num">&frac14; cup</td><td>Topping</td></tr>
									<tr><td>Chia seeds</td><td class="num">2 tbsp</td><td class="num">&frac12; cup</td><td>Topping, preferably soaked</td></tr>
									<tr><td>Berries</td><td class="num">&frac12; cup</td><td class="num">2 cups</td><td>Topping</td></tr>
								</tbody>
							</table>
						</div>
					</details>

					<details>
						<summary class="category-summary">Powder jar mix</summary>
						<p>Use the 14-serving column for a comfortable 1-gallon jar fill with some shake room. Keep hazelnuts, almonds, berries, EVOO, chia, and liquids out of the jar. Label weights: protein 2 scoops = 73g, collagen 1 scoop = 22.3g, cocoa 1 scoop = 5.76g. Cup estimates are approximate: protein scoop ~1/3 cup, collagen scoop ~1/4 cup, cocoa scoop ~1 tbsp.</p>
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>Ingredient</th>
										<th class="num">Per serving</th>
										<th class="num">&times;4 batch</th>
										<th class="num">&times;14 jar</th>
									</tr>
								</thead>
								<tbody>
									<tr><td>Blueprint Metabolic Protein</td><td class="num">1&frac12; scoops (55g; ~&frac12; cup)</td><td class="num">6 scoops (219g; ~2 cups)</td><td class="num">21 scoops (767g; ~7 cups)</td></tr>
									<tr><td>Collagen</td><td class="num">1 scoop (22.3g; ~&frac14; cup)</td><td class="num">4 scoops (89g; ~1 cup)</td><td class="num">14 scoops (312g; ~3&frac14; cups)</td></tr>
									<tr><td>Ground macadamias</td><td class="num">1 tbsp</td><td class="num">&frac14; cup</td><td class="num">14 tbsp (&frac78; cup)</td></tr>
									<tr><td>Ground walnuts</td><td class="num">1 tbsp</td><td class="num">&frac14; cup</td><td class="num">14 tbsp (&frac78; cup)</td></tr>
									<tr><td>Ground flax seeds</td><td class="num">1 tbsp</td><td class="num">&frac14; cup</td><td class="num">14 tbsp (&frac78; cup)</td></tr>
									<tr><td>Blueprint Cocoa</td><td class="num">1 scoop (5.76g; ~1 tbsp)</td><td class="num">4 scoops (23g; ~&frac14; cup)</td><td class="num">14 scoops (81g; ~&frac78; cup)</td></tr>
									<tr><td>Sunflower lecithin</td><td class="num">1 tsp</td><td class="num">1 tbsp + 1 tsp</td><td class="num">4 tbsp + 2 tsp</td></tr>
									<tr><td>Ceylon cinnamon</td><td class="num">&frac12; tsp</td><td class="num">2 tsp</td><td class="num">2 tbsp + 1 tsp</td></tr>
									<tr><td>Optional sumac</td><td class="num">&frac14; tsp</td><td class="num">1 tsp</td><td class="num">1 tbsp + &frac12; tsp</td></tr>
								</tbody>
							</table>
						</div>
						<p><strong>Mixing order:</strong> finest powders first (sumac if using, cinnamon, cocoa, lecithin, flax), then protein and collagen, then ground macadamias and walnuts. Shake hard to combine; shake before each scoop. Store the jar cold if keeping ground nuts or flax for more than a few days.</p>
					</details>
				</div>

				<!-- Second meal + pill batch 2 -->
				<div class="time-block">
					<h3>Second meal + pill batch 2</h3>
					<p><a href="https://blueprint.bryanjohnson.com">Blueprint super veggie</a> about half of days, otherwise pills with any meal.</p>
					<div class="table-wrapper">
						<table class="schedule-table">
							<thead>
								<tr>
									<th>Item</th>
									<th>Dose</th>
									<th class="num">$/yr</th>
								</tr>
							</thead>
							<tbody>
								{(schedule.meal_2 || []).map(item => (
									<tr>
										<td>{item.source_url ? <a href={item.source_url}>{item.name}</a> : item.name}</td>
										<td class="schedule-dose">{item.dose_notes}</td>
										<td class="num">{item.annual_cost > 0 ? `$${item.annual_cost}` : <em>bundled</em>}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<details>
						<summary class="category-summary">Super veggie recipe</summary>
						<p>Blueprint base recipe plus avocado, shallots, cabbage, crispy onions, and crispy garlic.</p>
						<ul>
							<li>Steamed broccoli, cauliflower, shiitake mushrooms</li>
							<li><a href="https://www.amazon.com/dp/B08BNPW71P">Black beluga lentils</a></li>
							<li><strong>Dressing:</strong> garlic, ginger, lime, cumin, apple cider vinegar</li>
							<li>Hemp seeds</li>
							<li>1 avocado</li>
							<li>Chopped shallots, cabbage</li>
							<li><a href="https://www.amazon.com/Fresh-Gourmet-Crispy-Onions-Ounce/dp/B00HHFWEPU">Crispy onions</a> + <a href="https://www.amazon.com/Fresh-Gourmet-Crispy-Lightly-Seasoned/dp/B07P5JHC6B">crispy garlic</a> (not healthy, just tasty)</li>
							<li>Hummus</li>

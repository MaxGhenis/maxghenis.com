	/* NP recipe toggle */
	.np-toggle {
		display: inline-flex;
		gap: 0;
		margin-left: 0.5rem;
		border: 1px solid rgba(15, 23, 42, 0.15);
		border-radius: 4px;
		overflow: hidden;
		vertical-align: middle;
	}

	.np-toggle-btn {
		background: transparent;
		border: none;
		padding: 0.125rem 0.625rem;
		font-size: 0.8125rem;
		font-weight: 600;
		cursor: pointer;
		color: var(--ink-muted);
		transition: all 0.15s ease;
	}

	.np-toggle-btn.active {
		background: var(--ink);
		color: #fff;
	}

	.np-toggle-btn:not(.active):hover {
		background: rgba(15, 23, 42, 0.05);
	}

	.np-qty {
		font-weight: 600;
		color: var(--ink);
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>('.np-toggle-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const servings = btn.dataset.servings;
			document.querySelectorAll('.np-toggle-btn').forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			document.querySelectorAll<HTMLElement>('.np-qty').forEach(qty => {
				const key = `x${servings}`;
				if (qty.dataset[key]) {
					qty.innerHTML = qty.dataset[key] as string;
				}
			});
		});
	});
</script>

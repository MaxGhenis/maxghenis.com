			<!-- Blueprint bundles -->
			<section>
				<h2>Blueprint bundles</h2>
				<p>I use <a href="https://blueprint.bryanjohnson.com">Blueprint</a> products for items where bundling is cheaper than buying individually. Each bundle contains multiple catalog items.</p>
				<div class="table-wrapper">
					<table>
						<thead>
							<tr>
								<th>Bundle</th>
								<th class="num">$/mo</th>
								<th class="num">Items used</th>
								<th class="num">Net value</th>
								<th>Verdict</th>
							</tr>
						</thead>
						<tbody>
							{bundles.map(b => (
								<tr>
									<td>
										<strong>{b.name}</strong>
										<details class="evidence-details">
											<summary>Contents</summary>
											<p>{b.items.join(', ')}</p>
										</details>
									</td>
									<td class="num">${b.monthly_cost}</td>
									<td class="num">{b.n_selected}/{b.n_total}</td>
									<td class="num">${b.net_value.toLocaleString()}</td>
									<td><span class={`verdict-badge ${b.worth_it ? 'verdict-yes' : 'verdict-no'}`}>{b.worth_it ? 'worth it' : 'not worth it'}</span></td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<!-- Portfolio optimization -->
			<section>
				<h2>Portfolio optimization</h2>
				<p>The optimizer greedily adds items by marginal net value (QALY gain &times; $200K &minus; cost), applying diminishing returns and a complexity penalty. It stops when the next item would have negative marginal value.</p>
				<p><strong>Result:</strong> {summary.total_items} items selected, +{Math.round(summary.total_days)} expected days ({(summary.total_days / 365.25).toFixed(1)} years), ${summary.total_annual_cost.toLocaleString()}/yr.</p>

				<details>
					<summary class="category-summary">Selection order ({portfolio.length} steps)</summary>
					<div class="table-wrapper">
						<table>
							<thead>
								<tr>
									<th>#</th>
									<th>Item added</th>
									<th class="num">+days</th>
									<th class="num">Marginal $</th>
									<th class="num">Cumulative $/yr</th>
									<th class="num">Ceiling retention</th>
								</tr>
							</thead>
							<tbody>
								{portfolio.map(p => (
									<tr>
										<td>{p.step}</td>
										<td>{p.name}</td>
										<td class="num">+{p.marginal_days.toFixed(0)}</td>
										<td class="num">${p.marginal_net_value.toLocaleString()}</td>
										<td class="num">${p.total_annual_cost.toLocaleString()}</td>
										<td class="num">{p.ceiling_retention != null && p.ceiling_retention < 1 ? p.ceiling_retention.toFixed(2) : '1.00'}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</details>

				{excluded.length > 0 && (
					<details>
						<summary class="category-summary">Excluded from portfolio ({excluded.length} items)</summary>
						<p class="excluded-note">Items not selected due to negative marginal value after diminishing returns and complexity penalty.</p>
						<div class="table-wrapper">
							<table>
								<thead>
									<tr>
										<th>Item</th>
										<th class="num">E[days]</th>
										<th class="num">$/yr</th>
										<th class="num">Net value</th>
										<th>Why excluded</th>
									</tr>
								</thead>
								<tbody>
									{excluded.map(s => (
										<tr>
											<td>{s.name}</td>

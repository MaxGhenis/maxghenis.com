			<!-- Exercise -->
			<section>
				<h2>Exercise</h2>
				<p>Daily morning workout, typically strength and cardio combined, following <a href="https://youtu.be/sYyVi-H-ozI?si=lq0qPorXlv9kCNW6">Bryan Johnson's workout protocol</a>. Consistency matters more than intensity &mdash; the goal is a sustainable daily habit, not periodic heroic sessions.</p>
			</section>

			<!-- Full catalog by category -->
			<section>
				<h2>Full catalog</h2>
				<p>All {supplements.length} items evaluated, organized by category. Items marked "bundled" are included in Blueprint products below.</p>

				{categories.filter(c => grouped[c.key]?.length > 0).map(cat => {
					const items = grouped[cat.key];
					const isCandidate = cat.key.includes('candidate');
					return (
						<details open={!isCandidate}>
							<summary class="category-summary">
								{cat.label} <span class="category-count">({items.length})</span>
							</summary>
							<div class="table-wrapper">
								<table>
									<thead>
										<tr>
											<th>Item</th>
											<th>Evidence</th>
											<th class="num">E[days]</th>
											<th class="num">P(+)</th>
											<th class="num">$/yr</th>
											<th class="num">Net value</th>
										</tr>
									</thead>
									<tbody>
										{items.map(s => (
											<tr class={s.in_portfolio ? '' : 'excluded-row'}>
												<td>
													<strong>{s.name}</strong>
													{s.in_portfolio && <span class="in-portfolio-mark" title="In optimized portfolio"> *</span>}
													<details class="evidence-details">
														<summary>Details</summary>
														<p>
														HR obs: {s.hr_observed} &rarr; pub-bias: {s.hr_corrected}
														{s.hr_posterior_median != null && <> &rarr; posterior: <strong>{s.hr_posterior_median.toFixed(3)}</strong></>}
														{s.study_quality && <> | tier: {s.study_quality.replace(/_/g, ' ')}</>}
														 | QoL: {s.qol_annual > 0 ? '+' : ''}{s.qol_annual}/yr
														<br/>{s.notes}{s.sources?.length > 0 && <><br/><a href={s.sources[0]}>Product link</a></>}
													</p>
													</details>
												</td>
												<td><span class={`evidence-badge evidence-${s.evidence}`}>{s.evidence}</span></td>
												<td class="num">+{s.days.toFixed(0)}</td>
												<td class="num">{Math.round(s.p_benefit * 100)}%</td>
												<td class="num">{(s.effective_annual_cost ?? s.annual_cost) === 0 ? 'bundled' : `$${Math.round(s.effective_annual_cost ?? s.annual_cost)}`}</td>
												<td class="num">${s.gross_value.toLocaleString()}</td>
											</tr>
										))}
									</tbody>
								</table>
							</div>

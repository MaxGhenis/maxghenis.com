	}

	.excluded-note {
		font-size: 0.875rem;
		color: var(--ink-muted);
		margin-bottom: 1rem;
	}

	.excluded-reason {
		font-size: 0.8125rem;
		color: var(--ink-muted);
		font-style: italic;
	}

	@media (max-width: 768px) {
		.page-header h1 {

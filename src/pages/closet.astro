---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Dryer disposition → badge label + style.
const dryMeta: Record<string, { label: string; cls: string }> = {
  tumble: { label: 'Tumble OK', cls: 'dry-good' },
  low: { label: 'Low only', cls: 'dry-warn' },
  hang: { label: 'Hang dry', cls: 'dry-warn' },
  air: { label: 'Air dry', cls: 'dry-warn' },
  flat: { label: 'Lay flat', cls: 'dry-bad' },
  dryclean: { label: 'Dry clean', cls: 'dry-bad' },
};

// Spin tracks the dry method — the gentler the dry, the lower the spin.
const spinFromDry: Record<string, string> = {
  tumble: 'High',
  low: 'Medium',
  hang: 'Low–med',
  air: 'Low–med',
  flat: 'Low',
  dryclean: '—',
};

// Wash loads — minimized to two machine loads plus a rare wool wash.
// The clothes load washes together; only the drying diverges.
interface Load {
  name: string;
  settings: string;
  note: string;
  dry?: string;
  items?: string[];
  drySort?: { dry: string; items: string }[];
}

const loads: Load[] = [
  {
    name: 'Clothes',
    settings: 'Cold · regular detergent · no softener · medium spin · wash together, sort at the dryer',
    drySort: [
      { dry: 'hang', items: 'Dress shirts, OCBDs, linen shirt, oatmeal linen trousers' },
      { dry: 'flat', items: 'Sunspel polos (cotton — wash here, just lay flat)' },
      { dry: 'air', items: 'Activewear — gym shorts, swim short' },
      { dry: 'tumble', items: 'Tees, socks, underwear, boxers, chinos, jeans' },
    ],
    note: 'Everything you wear in one cold wash — the only thing that changes is where it dries. New darks bleed at first, so run the blue selvedge OCBD on its own the first wash or two.',
  },
  {
    name: 'Linens',
    settings: 'Warm / hot · OxiClean · no softener · high spin · tumble dry',
    dry: 'tumble',
    items: ['Towels', 'Sheets & pillowcases'],
    note: 'Towels + sheets together. No softener — it kills towel absorbency. OxiClean is ideal here (oxygen bleach, color-safe). Combining leaves a little lint on the sheets; split towels off solo if that bugs you.',
  },
  {
    name: 'Wool — occasional',
    settings: 'Cold · wool wash (Eucalan) · low / no spin · lay flat · wash rarely',
    dry: 'flat',
    items: ['Olive merino quarter-zip', 'Wool & Prince merino tops & undershirts', 'Pantherella wool dress socks'],
    note: 'The only things that can’t ride in the clothes load — regular detergent’s enzymes digest wool. Merino is anti-odor, so this is every few weeks, and small enough to hand-wash in the sink.',
  },
  {
    name: 'Dry clean',
    settings: 'No machine — dry clean or steam between wears',
    dry: 'dryclean',
    items: ['Navy suit (jacket + trousers)', 'Glen plaid blazer'],
    note: 'Steam at home between wears; dry-clean sparingly.',
  },
];

// Full inventory, grouped by category.
const groups = [
  {
    title: 'Dress shirts',
    rows: [
      { item: 'Blue Japanese selvedge OCBD', sub: 'Todd Snyder', fabric: '100% cotton selvedge', wash: 'Cold, inside out, no softener, non-chlorine bleach only', dry: 'hang', notes: 'Wrinkles — iron warm while damp, keep the collar roll. Sheds dye the first wash or two (wash with darks).' },
      { item: 'White Favorite Oxford', sub: 'Todd Snyder', fabric: 'Cotton, stonewashed', wash: 'Cold, gentle, mild detergent', dry: 'hang', notes: 'Softer and lower-maintenance than the selvedge. Hang to keep the fit.' },
      { item: 'White cotton-linen shirt', sub: 'Suitsupply', fabric: 'Cotton-linen', wash: 'Cold, gentle', dry: 'hang', notes: 'Iron or steam; hang to dry.' },
      { item: 'White linen shirt', sub: '', fabric: 'Linen', wash: 'Cold, gentle', dry: 'hang', notes: 'Wrinkles by nature — that’s the look. Roll-packs fine.' },
    ],
  },
  {
    title: 'Knits & polos',
    rows: [
      { item: 'Olive merino quarter-zip', sub: '', fabric: 'Merino wool', wash: 'Cold / wool cycle or hand, wool wash (Eucalan)', dry: 'flat', notes: 'Never the dryer. Lay flat — hanging wet stretches the shoulders. Wash rarely; air it out instead.' },
      { item: 'Merino tops & undershirts', sub: 'Wool & Prince', fabric: 'Merino wool', wash: 'Cold, wool wash, gentle', dry: 'flat', notes: 'Same as the quarter-zip. Double as gym tops; anti-odor, so re-wear and wash seldom.' },
      { item: 'Sunspel polo — navy', sub: 'Sunspel', fabric: 'Cotton', wash: 'Cold, inside out, no softener', dry: 'flat', notes: 'Lay flat — hanging wet stretches it out. Runs trim; size up in Sunspel.' },
      { item: 'Sunspel polo — olive', sub: 'Sunspel', fabric: 'Cotton', wash: 'Cold, inside out, no softener', dry: 'flat', notes: 'Lay flat to dry, reshaped.' },
    ],
  },
  {
    title: 'Trousers',
    rows: [
      { item: 'Oatmeal linen Sutton', sub: 'Todd Snyder', fabric: 'Linen', wash: 'Cold, gentle', dry: 'hang', notes: 'Hang dry; iron or steam.' },
      { item: 'Khaki chino', sub: '', fabric: 'Cotton', wash: 'Cold (warm OK)', dry: 'low', notes: 'Durable; low-tumble is fine, hang to avoid any shrink/fade. Your single chino — pairs with everything.' },
      { item: 'Jeans', sub: '', fabric: 'Cotton denim', wash: 'Cold, inside out, wash rarely', dry: 'low', notes: 'Hang or low-tumble. Raw selvedge (when you get a pair): wash cold, sparingly, hang only.' },
    ],
  },
  {
    title: 'Tailoring & outerwear',
    rows: [
      { item: 'Navy suit', sub: '', fabric: 'Wool', wash: 'Dry clean / steam', dry: 'dryclean', notes: 'Never machine wash. Steam between wears; dry-clean sparingly.' },
      { item: 'Glen plaid blazer', sub: 'Suitsupply', fabric: 'Wool', wash: 'Dry clean / steam', dry: 'dryclean', notes: 'Same. The workhorse jacket — steam and air it, clean rarely.' },
      { item: 'Packable parka', sub: 'Uniqlo', fabric: 'Synthetic', wash: 'Machine wash cold, gentle (check label)', dry: 'low', notes: 'Tumble low or hang. No softener on technical fabric.' },
    ],
  },
  {
    title: 'Activewear',
    rows: [
      { item: 'Pace Breaker shorts', sub: 'Lululemon', fabric: 'Synthetic', wash: 'Cold, inside out, no softener', dry: 'air', notes: 'Air dry or lowest heat. Sport detergent or a vinegar soak for odor.' },
      { item: 'Swim short', sub: '', fabric: 'Synthetic', wash: 'Rinse after use; cold gentle if washed', dry: 'air', notes: 'Air dry only; doubles as a casual short.' },
    ],
  },
  {
    title: 'Base layers & socks',
    rows: [
      { item: 'Boxers ×8', sub: '', fabric: 'Cotton / synthetic', wash: 'Warm', dry: 'tumble', notes: 'Goes with whites (light) or everyday (dark). Tumble fine.' },
      { item: 'Pantherella dress socks ×4', sub: '', fabric: 'Wool blend', wash: 'Cold, wool wash', dry: 'flat', notes: 'Wash with the wool load; lay flat. Navy, charcoal, brown, black.' },
      { item: 'Athletic / no-show socks', sub: '', fabric: 'Synthetic / cotton', wash: 'Normal', dry: 'tumble', notes: 'Everyday load; tumble fine.' },
    ],
  },
  {
    title: 'Linens',
    rows: [
      { item: 'Towels', sub: '', fabric: 'Cotton', wash: 'Warm / hot, no softener', dry: 'tumble', notes: 'Own load. Softener kills absorbency; vinegar rinse occasionally.' },
      { item: 'Sheets', sub: '', fabric: 'Cotton', wash: 'Warm', dry: 'tumble', notes: 'Own load, weekly. Keep away from towels (lint).' },
    ],
  },
];

// Footwear — spot care, not laundry.
const footwear = [
  { item: 'AE Park Avenue oxfords', care: 'Saphir Renovator + horsehair brush; condition every ~10–15 wears. Cedar trees between wears. Never water or machine.' },
  { item: 'Hoka Clifton 10', care: 'Remove insoles & laces, cold gentle cycle in a mesh bag, air dry only — dryer heat wrecks the foam and glue. Crep Protect spray for water resistance.' },
  { item: 'Suede loafers', care: 'Suede brush + Crep Protect; no water. Spot-clean with a suede eraser.' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Closet | ${SITE_TITLE}`}
      description="Everything I own and how to wash it — by garment, by wash load, and what's safe for the dryer."
    />
  </head>
  <body>
    <Header />
    <main>
      <header class="page-header">
        <h1>Closet</h1>
        <p class="page-description">
          What I own and how to wash it — sorted by wash load, by garment, and by
          what survives the dryer.
        </p>
      </header>

      <div class="callout">
        <strong>The whole system in one line:</strong> one cold load for your clothes,
        one warm load for towels and sheets, and a rare cold wash for the wool — then
        sort the clothes load at the dryer.
      </div>

      <section>
        <h2>By load</h2>
        <p>
          Minimized to two machine loads plus a rare wool wash. The trick: wash
          together, then sort at the dryer.
        </p>
        <div class="loads">
          {loads.map((load) => (
            <div class="load-card">
              <div class="load-head">
                <h3>{load.name}</h3>
                {load.dry && (
                  <span class={`dry-badge ${dryMeta[load.dry].cls}`}>{dryMeta[load.dry].label}</span>
                )}
              </div>
              <p class="load-settings">{load.settings}</p>
              {load.drySort ? (
                <div class="dry-sort">
                  {load.drySort.map((g) => (
                    <div class="sort-row">
                      <span class={`dry-badge ${dryMeta[g.dry].cls}`}>{dryMeta[g.dry].label}</span>
                      <span class="sort-items">{g.items}</span>
                    </div>
                  ))}
                </div>
              ) : (
                <ul class="load-items">
                  {load.items?.map((it) => <li>{it}</li>)}
                </ul>
              )}
              <p class="load-note">{load.note}</p>
            </div>
          ))}
        </div>
        <p class="loads-foot">
          Two compromises, neither does any damage: white basics washed cold with
          colors slowly dull (fine for socks and tees — your white dress shirts hang
          either way), and towels share a little lint with the sheets. Want crisp
          whites and lint-free sheets? Split into three — clothes (cold), whites +
          sheets (warm + OxiClean), towels solo.
        </p>
      </section>

      <section>
        <h2>By garment</h2>
        <p>Every piece, its fabric, how it washes, the spin, and whether it can go in the dryer. Spin is the most each item should take; in the combined clothes load, run the gentlest (medium).</p>
        {groups.map((group) => (
          <div class="garment-group">
            <h3>{group.title}</h3>
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th>Item</th>
                    <th>Fabric</th>
                    <th>Wash</th>
                    <th>Spin</th>
                    <th>Dryer</th>
                    <th>Notes</th>
                  </tr>
                </thead>
                <tbody>
                  {group.rows.map((row) => (
                    <tr>
                      <td class="cell-item">
                        {row.item}
                        {row.sub && <span class="item-sub">{row.sub}</span>}
                      </td>
                      <td>{row.fabric}</td>
                      <td>{row.wash}</td>
                      <td class="cell-spin">{spinFromDry[row.dry]}</td>
                      <td><span class={`dry-badge ${dryMeta[row.dry].cls}`}>{dryMeta[row.dry].label}</span></td>
                      <td class="cell-notes">{row.notes}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </section>

      <section>
        <h2>Detergents</h2>
        <ul>
          <li><strong>Wool &amp; delicates:</strong> Eucalan (no-rinse) or The Laundress Wool &amp; Cashmere — enzyme-free, so it won’t eat the merino.</li>
          <li><strong>Everything else:</strong> a normal detergent (Dirty Labs or Tide Free &amp; Gentle). Keep it off wool.</li>
          <li><strong>Activewear:</strong> a sport detergent (Hex, WIN) or a ½-cup white-vinegar cold soak for odor.</li>
          <li><strong>Whites, towels &amp; sheets:</strong> an oxygen brightener (OxiClean) on warm — color-safe, lifts body oils and yellowing.</li>
        </ul>
      </section>

      <section>
        <h2>Footwear</h2>
        <p>Spot care, not laundry.</p>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Pair</th><th>Care</th></tr>
            </thead>
            <tbody>
              {footwear.map((f) => (
                <tr>
                  <td class="cell-item">{f.item}</td>
                  <td class="cell-notes">{f.care}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    </main>
    <Footer />

    <style>
      main {
        max-width: 1000px;
      }

      .page-header {
        margin-bottom: 2rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      }

      .page-header h1 {
        font-size: 3rem;
        margin-bottom: 0.75rem;
      }

      .page-description {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 640px;
      }

      .callout {
        background: #fef3c7;
        border-left: 4px solid #f59e0b;
        padding: 1rem 1.25rem;
        border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
        margin-bottom: 3rem;
        color: #78350f;
        line-height: 1.6;
        font-size: 0.9375rem;
      }

      section {
        margin-bottom: 3.5rem;
      }

      section > h2 {
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
      }

      section > p {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
      }

      section ul {
        color: var(--text-secondary);
        line-height: 1.6;
        padding-left: 1.5rem;
      }

      section li {
        margin-bottom: 0.5rem;
      }

      /* Dryer badges */
      .dry-badge {
        display: inline-block;
        white-space: nowrap;
        padding: 0.15rem 0.55rem;
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        border: 1px solid transparent;
      }
      .dry-good { background: rgba(132, 204, 22, 0.15); color: #3f6212; border-color: rgba(132, 204, 22, 0.4); }
      .dry-warn { background: rgba(245, 158, 11, 0.15); color: #92400e; border-color: rgba(245, 158, 11, 0.4); }
      .dry-bad { background: rgba(190, 24, 24, 0.10); color: #991b1b; border-color: rgba(190, 24, 24, 0.3); }

      /* Load cards */
      .loads {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .dry-sort {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 0.85rem;
      }
      .sort-row {
        display: flex;
        align-items: baseline;
        gap: 0.65rem;
      }
      .sort-row .dry-badge {
        flex-shrink: 0;
        min-width: 5.5rem;
        text-align: center;
      }
      .sort-items {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.4;
      }
      .loads-foot {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.55;
        margin-top: 1.25rem;
      }
      .load-card {
        background: var(--cream-dark);
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: var(--radius-lg);
        padding: 1.25rem 1.35rem;
      }
      .load-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .load-head h3 {
        font-size: 1.2rem;
        margin: 0;
      }
      .load-settings {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        margin: 0 0 0.75rem 0;
        line-height: 1.5;
      }
      .load-items {
        list-style: none;
        padding: 0;
        margin: 0 0 0.75rem 0;
      }
      .load-items li {
        font-size: 0.9rem;
        color: var(--text-secondary);
        padding: 0.15rem 0;
        border-bottom: 1px dashed rgba(15, 23, 42, 0.06);
      }
      .load-items li:last-child { border-bottom: none; }
      .load-note {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.55;
        margin: 0;
      }

      /* Garment tables */
      .garment-group { margin-bottom: 2rem; }
      .garment-group h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
      }
      .table-wrapper { overflow-x: auto; }
      table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
      th, td {
        text-align: left;
        padding: 0.6rem 0.85rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        vertical-align: top;
      }
      th { font-weight: 600; color: var(--ink); font-size: 0.82rem; background: var(--bg-secondary); }
      td { color: var(--text-secondary); }
      .cell-item { font-weight: 600; color: var(--ink); min-width: 9rem; }
      .item-sub { display: block; font-weight: 400; font-size: 0.78rem; color: var(--text-muted); }
      .cell-notes { font-size: 0.82rem; color: var(--text-muted); min-width: 14rem; }
      .cell-spin { font-size: 0.82rem; white-space: nowrap; color: var(--text-secondary); }

      @media (max-width: 720px) {
        .page-header h1 { font-size: 2.25rem; }
        .sort-row { flex-direction: column; gap: 0.2rem; }
      }
    </style>
  </body>
</html>
